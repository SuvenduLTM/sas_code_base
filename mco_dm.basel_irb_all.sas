proc sql;
   create view work.W9YBMXE0 as
      select
         information_date,
         bank_id,
         account_id,
         ead_amount,
         ead_amount_obs,
         credit_amount,
         conversion_factor_type,
         conversion_factor_pct,
         credit_amount_obs,
         conversion_factor_type_obs,
         conversion_factor_pct_obs,
         sm_amount,
         sm_amount_obs,
         irb_amount,
         irb_amount_obs,
         credit_risk_type,
         risk_weighted_asset_amount,
         risk_weight_pct,
         expected_loss_amount,
         sm_exposure_class,
         irb_customer_group,
         sm_originating_exposure_class,
         irb_exposure_class,
         pd_class_pct,
         pd_class_number,
         lgd_class_pct,
         lgd_class_number,
         nbr_of_counterparties,
         company_housing_30_amount,
         crm_amount,
         housing_collateral_amount,
         other_collateral_amount,
         maturity,
         calculated_ead,
         supporting_factor_class_number,
         currency,
         bank_group_currency,
         exchange_rate,
         country_code,
         impairment_losses_amount,
         counterparty_risk_type,
         source_system_cd,
         extracted_dt,
         b_bank_id,
         b_row_number,
         b_exposure_class,
         b_irb_customer_group,
         b_sm_originating_exposure_class,
         b_exposure_amount,
         b_sm_risk_weight_pct,
         b_conversion_factor_pct,
         b_conversion_factor_type,
         b_balance_sheet,
         b_source_system_cd,
         exposure_value,
         risk_exposure_amount,
         risk_exposure_amount_sf,
         loaded_dt,
         irb_risk_exposure_amount_sf,
         customer_id,
         stat_sector_cd,
         customer_ssn_id,
         customer_name,
         entity_customer_id,
         entity_ssn_id,
         new_default_flg,
         account_number_official,
         ecl_amount,
         (case when (credit_amount + credit_amount_obs)=0 then . else ecl_amount * (b_exposure_amount/(credit_amount + credit_amount_obs)) end) as b_ecl_amount length = 8
            format = 15.2
            label = 'ECL amount row share for the account: ecl_amount * (b_exposure_amount/(credit_amount + credit_amount_obs))',
         stage_cd,
         (b_exposure_amount - CALCULATED b_ecl_amount) as b_exposure_net_amount length = 8
            format = 15.2
            label = 'Exposure_amount - ECL_amount',
         (CALCULATED b_exposure_net_amount * b_conversion_factor_pct) as exposure_value_ifrs9_amount length = 8
            format = 15.2
            label = 'IFRS9 exposure value: calculated exposure_value - ECL_value',
         (CALCULATED exposure_value_ifrs9_amount * b_sm_risk_weight_pct) as risk_exposure_ifrs9_amount length = 8
            format = 15.2
            label = 'IFRS9 risk exposure: calculated exposure_value_ifrs9_amount * b_sm_risk_weight_pct',
         (case when supporting_factor_class_number=1 then 
            CALCULATED risk_exposure_ifrs9_amount * supporting_factor_pct else 
            CALCULATED risk_exposure_ifrs9_amount end) as risk_exposure_sf_ifrs9_amount length = 8
            format = 15.2
            label = 'IFRS9 risk exposure adjusted by supporting factor: calculated risk_exposure_ifrs9_amount * 0.7619 in case supporting_factor_class_number=1, else risk_exposure_ifrs9_amount',
         lei,
         lei_expiry_date,
         supporting_factor_pct
   from &SYSLAST
   ;
quit;

