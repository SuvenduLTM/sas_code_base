      DET_COREP_ECL.ecl_amount length = 8   
         format = 15.2
         label = 'ECL amount',
      DET_COREP_ECL.stage_cd length = 3   
         format = 6.
         label = 'Stage, eg. 1, 2, 3',
      W89U0O7K.lei length = 20   
