      W1KH28N4.default_end_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Default end date',
      W1KH28N4.default_trigger_account_id length = 14   
         label = 'The account id for the credit that triggered the default.'
   from
      work.W1KH28N4 as W1KH28N4
   group by
      W1KH28N4.information_date,
