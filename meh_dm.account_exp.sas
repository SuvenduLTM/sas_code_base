proc sql;
  create table due12mth as 
  select credit_id 
         ,&active_date as INFORMATION_DATE format=date9. /* summering ska göras PER det aktuella datum man kör för*/
		 ,information_date as INFODATE /*underlagets information_date*/
		 ,intck('Month', information_date, &active_date.) as mthDiff
		 ,number_of_days1
         ,max( case when intck('Month', information_date, &active_date.) = 0 and number_of_days1>0 then 1 else 0 end ) as maxNo1
         ,max( case when intck('Month', information_date, &active_date.) = 1 and number_of_days1>0 then 1 else 0 end ) as maxNo2
         ,max( case when intck('Month', information_date, &active_date.) = 2 and number_of_days1>0 then 1 else 0 end ) as maxNo3
         ,max( case when intck('Month', information_date, &active_date.) = 3 and number_of_days1>0 then 1 else 0 end ) as maxNo4
         ,max( case when intck('Month', information_date, &active_date.) = 4 and number_of_days1>0 then 1 else 0 end ) as maxNo5
         ,max( case when intck('Month', information_date, &active_date.) = 5 and number_of_days1>0 then 1 else 0 end ) as maxNo6
         ,max( case when intck('Month', information_date, &active_date.) = 6 and number_of_days1>0 then 1 else 0 end ) as maxNo7
         ,max( case when intck('Month', information_date, &active_date.) = 7 and number_of_days1>0 then 1 else 0 end ) as maxNo8
         ,max( case when intck('Month', information_date, &active_date.) = 8 and number_of_days1>0 then 1 else 0 end ) as maxNo9
         ,max( case when intck('Month', information_date, &active_date.) = 9 and number_of_days1>0 then 1 else 0 end ) as maxNo10
         ,max( case when intck('Month', information_date, &active_date.) = 10 and number_of_days1>0 then 1 else 0 end ) as maxNo11
         ,max( case when intck('Month', information_date, &active_date.) = 11 and number_of_days1>0 then 1 else 0 end ) as maxNo12
  from  dwh_dw.CREDIT_DUE_AMT_CREDIT_LVL
  group by credit_id 
  having intck('Month', information_date, &active_date.) <= 12
  order by information_date;
quit;

proc sql;
   create table months_with_due_12mth as
   select distinct INFORMATION_DATE, credit_id, sum(maxNo1,maxNo2,maxNo3,maxNo4,maxNo5,maxNo6,maxNo7,maxNo8,maxNo9,maxNo10,maxNo11,maxNo12 ) as months_with_due_12mth  
   from due12mth
   group by credit_id, INFORMATION_DATE;
quit;



