option DBIDIRECTEXEC;

proc datasets lib = work nolist nowarn memtype = (data view);
   delete Credit_terms;
quit;

proc sql;
   create table work.Credit_terms as
   select distinct
      ACCOUNT_CREDIT_LINK.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'The date for the information in the current file yyyyMMdd',
      ACCOUNT_CREDIT_LINK.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden, C=Borgo',
      ACCOUNT_CREDIT_LINK.credit_id length = 8   
         format = 15.
         label = 'Credit ID (internal)',
      ACCOUNT_CREDIT_LINK.account_id length = 14   
         label = 'Account number (internal)',
      CREDIT_TERMS_CHANGE.deferment_id length = 8   
         format = 15.
         label = 'Unique ID for change in terms (“villkorsändring”)',
      CREDIT_TERMS_CHANGE.deferment_dec length = 4   
         format = 4.
         label = 'Number of deferments',
      max(CREDIT_TERMS_CHANGE.deferment_start_date) as max_deferment_start_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Start date for default. Missing date = 0',
      CREDIT_TERMS_CHANGE.deferment_end_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'End date for default. Missing date = 0',
      CREDIT_TERMS_CHANGE.deferment_payment_free_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Payment free months, date. Missing date = 0',
      CREDIT_TERMS_CHANGE.customer_type length = 3   
         format = 3.
         label = 'Customer group: eg. 1 = private customer',
      CREDIT_TERMS_CHANGE.terms_type length = 3   
         label = 'Terms type for change:- DEF = ‘Anstånd’- MOR = ‘Moratorium’- OTH = ‘Övrig villkorsändring’: eg. Codes:- DEF - MOR- OTH',
      CREDIT_TERMS_CHANGE.sustainable_flag length = 3   
         format = 3.
         label = 'Flag for sustainability: eg. J  = Yes N = No',
      CREDIT_TERMS_CHANGE.other_reason length = 78   
         label = 'Reason text for other reason'
   from
      dwh_dw.ACCOUNT_CREDIT_LINK
      (
         &altercommand.
      ) as ACCOUNT_CREDIT_LINK, 
      dwh_dw.CREDIT_TERMS_CHANGE
      (
         &altercommand.
      ) as CREDIT_TERMS_CHANGE
   where
      ACCOUNT_CREDIT_LINK.information_date = CREDIT_TERMS_CHANGE.information_date
      and ACCOUNT_CREDIT_LINK.bank_id = CREDIT_TERMS_CHANGE.bank_id
      and ACCOUNT_CREDIT_LINK.credit_id = CREDIT_TERMS_CHANGE.credit_id
      and CREDIT_TERMS_CHANGE.terms_type = 'DEF'
   group by
      ACCOUNT_CREDIT_LINK.information_date,
      ACCOUNT_CREDIT_LINK.bank_id,
      ACCOUNT_CREDIT_LINK.credit_id,
      ACCOUNT_CREDIT_LINK.account_id
   having
      max_deferment_start_date = CREDIT_TERMS_CHANGE.deferment_start_date
   ;
quit;

