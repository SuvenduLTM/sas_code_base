proc datasets lib = work nolist nowarn memtype = (data view);
   delete QUALITATIVE_JUDGEMENT_AGGR;
quit;

proc sql;
   create table work.QUALITATIVE_JUDGEMENT_AGGR as
   select distinct
      QUALITATIVE_JUDGEMENT.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Information date of the record',
      QUALITATIVE_JUDGEMENT.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      QUALITATIVE_JUDGEMENT.judgement_id length = 4   
         format = 10.
         label = 'Qualitative judgment record id.',
      QUALITATIVE_JUDGEMENT.customer_id as owner_id length = 9   
         label = 'CBS customer number',
      QUALITATIVE_JUDGEMENT.expire_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Qualitative judgement expiry date',
      QUALITATIVE_JUDGEMENT.pd_class_cd as qa_pd_class_cd length = 4   
         format = 5.
         label = 'Qualitative judgement pd class number'
   from
      work.QUALITATIVE_JUDGEMENT as QUALITATIVE_JUDGEMENT
   where
      QUALITATIVE_JUDGEMENT.expire_date >= QUALITATIVE_JUDGEMENT.information_date
   group by
      QUALITATIVE_JUDGEMENT.information_date,
      QUALITATIVE_JUDGEMENT.bank_id,
      QUALITATIVE_JUDGEMENT.customer_id
   having
      QUALITATIVE_JUDGEMENT.expire_date = max(QUALITATIVE_JUDGEMENT.expire_date)
   order by
      QUALITATIVE_JUDGEMENT.information_date,
      QUALITATIVE_JUDGEMENT.bank_id,
      QUALITATIVE_JUDGEMENT.customer_id,
      QUALITATIVE_JUDGEMENT.judgement_id desc,
      QUALITATIVE_JUDGEMENT.pd_class_cd desc
   ;
quit;

