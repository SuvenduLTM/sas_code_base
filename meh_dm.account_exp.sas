 *                   work.credit_in_default                                 * 
 *                  RISK_CUSTOMER_COMPANY -               A5M8HTKH.BR0002CC * 
 *                   work.risk_customer_company                             * 
 *                  GUARANTEE_OBJECT... - work.account_25 A5M8HTKH.BR0002CG * 
 *                  lifetime_llg_par -                    A5M8HTKH.BR0002CI * 
 *                   work.lifetime_llg_par                                  * 
 *                  QUALITATIVE_JUDGEMENT aggregate -     A5M8HTKH.BR0002CL * 
 *                   work.QUALITATIVE_JUDGEMENT_AGGR                        * 
 *                  EXCHANGE_RATES_EUR -                  A5M8HTKH.BR0002CN * 
 *                   work.EXCHANGE_RATES_EUR                                * 
 *                  EXCHANGE_RATES_SEK -                  A5M8HTKH.BR0002CO * 
 *                   work.EXHANGE_RATES_SEK                                 * 
 *                  ecl_llg - work.stage_llg              A5M8HTKH.BR0002CP * 
 *                  fixed calculated end date -           A5M8HTKH.BR0002CJ * 
 *                   work.calculated_end_date_fixed                         * 
 *                  loan_application -                    A5M8HTKH.BR000472 * 
 *                   work.loan_application                                  * 
 *                  Credit cust lvl - work.cust_cred_lvl  A5M8HTKH.BR0004IO * 
 *                  Credit terms - work.Credit_terms      A5M8HTKH.BR0004KI * 
 * Target Table:    Account_28 - work.account_28          A5M8HTKH.BR0002CQ * 
 *==========================================================================*/ 

%let transformID = %quote(A5M8HTKH.BU0003EW);
%let trans_rc = 0;
%let etls_stepStartTime = %sysfunc(datetime(), datetime20.); 

%global etls_sql_pushDown;
%let etls_sql_pushDown = -1;
option DBIDIRECTEXEC;

proc datasets lib = work nolist nowarn memtype = (data view);
   delete account_28;
quit;

data _null_;
   put "NOTE: The following column(s) do not have a column mapping, so the"
        " value(s) will be set to missing: next_interest_payment_date,"
        " action_status_cd, performing_status_cd,    forbearance_txt,"
        " action_txt, performing_txt";
run;

proc sql;
   create table work.account_28 as
   select
      account_08.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Information date of the record',
      account_08.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      account_08.account_id length = 20   
         label = 'Account Number',
      account_08.booked_balance_amt length = 8   
         format = 15.2
         label = 'Booked Balance,Amount 15,2 (2 decimals)',
      account_08.credit_ref_interest_cd length = 10   
         label = 'Credit : Reference interest code',
      account_08.credit_interest_rate_pct length = 8   
         format = 8.4
         label = 'Credit: Interest rate (today). Ref.rate + Margin',
      account_08.credit_margin_rate_pct length = 8   
         format = 8.4
         label = 'Credit: Margin rate (today) - Customer marginal.',
      account_08.interest_start_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Interest period From date',
      account_08.interest_end_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Interest period To date',
      account_08.credit_interest_estimate_amt length = 8   
         format = 15.2
         label = 'Interest estimated - Credit',
      account_08.credit_interest_accrued_amt length = 8   
         format = 15.2
         label = 'Interest accrued - Credit',
      account_08.account_number_official length = 20   
         label = 'Account Number, official, In Finland this field is same as ACCNBR, in Sweden it contains the official Swedish account number.',
      account_08.account_type_cd length = 3   
         label = 'CBS Account Type',
      account_08.currency_cd length = 3   
         label = 'Account Currency',
      account_08.owner1_id length = 9   
         label = 'CBS Customer ID. Account owner',
      account_08.owner2_id length = 9   
         label = 'CBS Customer ID. Account owner 2',
      account_08.opened_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Account opened date',
      account_08.customer_id length = 9   
         label = 'CBS Customer ID',
      account_08.owner1_ssn_id length = 20   
         label = 'Social security / organisation number',
      account_08.owner2_ssn_id length = 20   
         label = 'Secondary owner´s social security / organisation number',
      account_08.customer_type length = 3   
         format = 3.
         label = '1=Private, 2=Coorp.cust.',
      account_08.owner1_age length = 8   
         format = 15.2
         informat = 15.2
         label = 'Primary owner´s age in years',
      account_08.owner2_age length = 8   
         format = 15.2
         informat = 15.2
         label = 'Secondary owner´s age in years',
      account_08.owner1_gender_cd length = 3   
         format = 3.
         label = 'Gender: 0 = Company, 1 =Male, 2 = Female',
      account_08.owner2_gender_cd length = 3   
         format = 3.
         label = 'Secondary owner´s gender: 0 = Company, 1 =Male, 2 = Female',
      account_08.post_office_number length = 10   
         label = 'Post office number',
      account_08.country_cd length = 2   
         label = 'Address-country code',
      account_08.result_office_id length = 2   
         label = 'Customers office-number',
      account_08.owner1_legal_form_cd length = 2   
         label = 'Juridisk Form',
      account_08.owner2_legal_form_cd length = 2   
         label = 'Secondary owner´s legal form',
      account_08.stat_sector_cd length = 6   
         label = 'Sektorkod. Obs : 6 siffror.',
      account_08.stat_branch_cd length = 6   
         label = 'Näringsgren. Obs: 6 siffror i kundreg. Ngrenkp färre siffror (fyll ut med nollor)',
      account_08.trade_register_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Registration date for Trade Register of corporate customer  (Reg.datum Handels/Föreningsregister)',
      account_08.capital_coverage_cd length = 4   
         label = 'Coverage (Kapitaltäckning), only used for corporate customers',
      basel_irb.pd_class_pct length = 8   
         format = 10.7
         label = 'Probability default class percentage',
      basel_irb.pd_class_number length = 3   
         format = 2.
         label = 'Probability default class number',
      basel_irb.nbr_of_counterparties length = 3   
         format = 3.
         label = 'Number of counterparties',
      basel_irb.calculated_ead length = 8   
         format = 15.2
         label = 'Exposure at default amount where interest is included.',
      basel_irb.portfolio_cd length = 1   
         label = 'Portfolio: 1 = Household portfolio, 2 = Company in household portfolio, 3 = Company portfolio',
      basel_irb.pd_under_model_number length = 3   
         format = 3.
         label = 'PD under model number',
      loan_additional_data.payment_plan_cd length = 1   
         label = 'Payment plan (0 = No, 1= Fixed, 2 = Annuity, 3 = Straight amortization, 4= Bullet)',
      loan_additional_data.next_principal_payment_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Next principal payment date',
      . as next_interest_payment_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Next interest payment date',
      loan_additional_data.next_interest_change_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Next interest change date',
      coalesce(loan_additional_data.purpose_of_use_cd, LIMIT.purpose_cd) as purpose_of_use_cd length = 4   
         label = 'The loans purpose of use',
      loan_additional_data.loan_end_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'The contractual loan end date',
      loan_additional_data.withdrawable_today_amount length = 8   
         format = 15.2
         label = 'Amount that can be withdrawn today',
      loan_additional_data.total_withdrawable_amount length = 8   
         format = 15.2
         label = 'Total withdrawable amount',
      loan_additional_data.payment_plan_principal length = 12   
         label = 'The payment plan for the principal repayments',
      loan_additional_data.payment_plan_interest length = 12   
         label = 'The payment plan interest payments',
      case when account_08.account_type_cd between '800' and '899' and basel_irb.portfolio_cd ='1' 
       then coalesce(BANK_GUARANTEE.end_date, intnx('year',account_08.opened_date,lifetime_llg_par.end_date_missing_ph_gu,'s'), 
         intnx('year',account_08.information_date,int(lifetime_llg_par.end_date_missing_ph_gu/2),'s'))
      when account_08.account_type_cd between '800' and '899' and basel_irb.portfolio_cd in('2','3') 
       then coalesce(BANK_GUARANTEE.end_date, intnx('year',account_08.opened_date,lifetime_llg_par.end_date_missing_fx_gu,'s'), 
        intnx('year',account_08.information_date,int(lifetime_llg_par.end_date_missing_fx_gu/2),'s'))
      when (account_08.account_type_cd='370' or account_08.account_type_cd between '400' and '499') and basel_irb.portfolio_cd ='1' 
       then coalesce(BANK_GUARANTEE.end_date, intnx('year',LIMIT.changed_date,lifetime_llg_par.end_date_missing_ph_li,'s'), 
        intnx('year',account_08.information_date,int(lifetime_llg_par.end_date_missing_ph_li/2),'s'))
      when (account_08.account_type_cd='370' or account_08.account_type_cd between '400' and '499') and basel_irb.portfolio_cd in('2','3') 
       then coalesce(BANK_GUARANTEE.end_date, intnx('year',LIMIT.changed_date,lifetime_llg_par.end_date_missing_fx_li,'s'), 
        intnx('year',account_08.information_date,int(lifetime_llg_par.end_date_missing_fx_li/2),'s'))
      when account_08.account_type_cd='501' and basel_irb.portfolio_cd in('1','2','3') 
       then coalesce(loan_additional_data.loan_end_date, intnx('year',account_08.opened_date,lifetime_llg_par.end_date_missing_ph_dl,'s'), 
        intnx('year',account_08.information_date,int(lifetime_llg_par.end_date_missing_ph_dl/2),'s'))
      when basel_irb.portfolio_cd ='1' 
       then coalesce(loan_additional_data.loan_end_date, intnx('year',account_08.opened_date,lifetime_llg_par.end_date_missing_ph_lo,'s'), 
        intnx('year',account_08.information_date,int(lifetime_llg_par.end_date_missing_ph_lo/2),'s'))
      when basel_irb.portfolio_cd in('2','3') 
       then coalesce(loan_additional_data.loan_end_date, intnx('year',account_08.opened_date,lifetime_llg_par.end_date_missing_fx_lo,'s'), 
        intnx('year',account_08.information_date,int(lifetime_llg_par.end_date_missing_fx_lo/2),'s'))
      else loan_additional_data.calculated_end_date 
      end as calculated_end_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Calculated end date',
      loan_additional_data.original_end_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Original end date',
      coalesce(LIMIT.overdraft_interest_pct, BANK_GUARANTEE.penalty_interest_pct, loan_additional_data.penalty_interest_pct) as penalty_interest_pct length = 8   
         format = 8.4
         label = 'Penalty interest percent',
      loan_additional_data.unmanaged_days_cnt length = 8   
         label = 'Number of days the loan has been unmanaged.',
      loan_additional_data.unmanaged_days_max_cnt length = 8   
         label = 'Max number of days the loan has been unmanaged during the month.',
      loan_additional_data.total_due_interest_amount length = 8   
         format = 15.2
         label = 'Total due interest amount',
      loan_additional_data.total_due_principal_amount length = 8   
         format = 15.2
         label = 'Total due principal amount',
      BANK_GUARANTEE.commission_pct length = 8   
         format = 10.4
         label = 'Commission percent',
      BANK_GUARANTEE.payment_plan_principal_txt length = 12   
         label = 'The payment plan for the principal repayments : eg. 100100100100',
      BANK_GUARANTEE.payment_plan_commission_txt length = 12   
         label = 'The payment plan commission payments : eg. 111111111111',
      BANK_GUARANTEE.commission_amt length = 8   
         format = 15.2
         label = 'Commission amount',
      BANK_GUARANTEE.opening_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Opening date',
      BANK_GUARANTEE.commission_payments_yearly_cnt length = 4   
         format = 8.
         label = 'Number of commission payments per year: eg. 12',
      BANK_GUARANTEE.end_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'End date for the bank guarantee',
      LIMIT.changed_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Last changed date',
      LIMIT.current_limit_amt length = 8   
         format = 15.2
         label = 'Current limit amount',
      LIMIT.max_limit_amt length = 8   
         format = 15.2
         label = 'Maximum amount usable during the month',
      LIMIT.provision_rate_pct length = 8   
         format = 10.4
         label = 'Provision rate %',
      LIMIT.provision_start_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Provision period: start date',
      LIMIT.provision_end_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Provision period: end date',
      LIMIT.provision_limit_amt length = 8   
         format = 15.2
         label = 'Total provision amount, charged at start of period',
      LIMIT.provision_accum_amt length = 8   
         format = 15.2
         label = 'Currently accumulated provision',
      LIMIT.provision_left_amt length = 8   
         format = 15.2
         label = 'Provision remaining in period',
      LIMIT.overdraft_days_cnt length = 3   
         format = 3.
         label = 'Number of days currently overdrawn, from RISK system',
      LIMIT.overdraft_days_max_cnt length = 3   
         format = 3.
         label = 'Maximum number of days overdrawn, from RISK system',
      LIMIT.limit_capitalized_mon_cnt length = 3   
         format = 3.
         label = 'Limit capitalization frequency in months',
      balance_average.balance_average_amt length = 8   
         format = 15.2
         label = 'Monthly average balance',
      credit_in_default.default_reason_cd length = 3   
         label = 'Default reason code',
      credit_in_default.default_start_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Default begin date',
      credit_in_default.default_end_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Default end date',
      credit_in_default.default_trigger_account_id length = 14   
         label = 'The account id for the credit that triggered the default.',
      case 
         when Credit_terms.terms_type = 'DEF'
         then 1
        else . 
      end as forbearance_status_cd length = 3   
         format = 3.
         label = 'Forbearance status',
      case 
         when Credit_terms.terms_type = 'DEF' then Credit_terms.max_deferment_start_date 
         else .
      end as forbearance_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Forbearance date',
      . as action_status_cd length = 3   
         format = 3.
         label = 'Action status',
      . as performing_status_cd length = 3   
         format = 3.
         label = 'Performing status',
      "" as forbearance_txt length = 260   
         label = 'User specified forbearance text',
      "" as action_txt length = 260   
         label = 'User specified action text',
      "" as performing_txt length = 260   
         label = 'User specified performing text',
      risk_customer_company.special_lending_flag length = 3   
         format = 3.
         label = 'Special lending: 1=Yes, 0=No, .=unknown',
      account_25.guarantors_cnt length = 4   
         format = 8.
         label = 'Number of guarantors',
      risk_customer_company.form_type_cd length = 3   
         format = 3.
         label = 'Rating done with or without financial statements (0 … 6)',
      risk_customer_company.rating_point length = 3   
         format = 3.
         label = 'Rating point (Finland): 0 … 99',
      risk_customer_company.uc_pct length = 8   
         format = 10.4
         label = 'UC-percent (Sweden)',
      case 
        when account_08.account_type_cd between '800' and '899' then BANK_GUARANTEE.end_date
        when (account_08.account_type_cd='370' or account_08.account_type_cd between '400' and '499') then .
        else loan_additional_data.loan_end_date 
      end as contractual_end_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Contractual end date (end_date for guaranties, loan_end_date for loans)',
      case 
        when account_08.account_type_cd between '800' and '899' then account_08.opened_date
        when (account_08.account_type_cd='370' or account_08.account_type_cd between '400' and '499') then LIMIT.changed_date
        else account_08.opened_date 
      end as initial_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Initial date (changed_date for limits, account opened_date for loans and guaranties)',
      QUALITATIVE_JUDGEMENT_AGGR.qa_pd_class_cd length = 4   
         format = 5.
         label = 'Qualitative judgement pd class number',
      account_08.owner1_party_ssn_id length = 20   
         label = 'Owner 1 full SSN / organisation ID (if party matches a customer)',
      account_08.owner2_party_ssn_id length = 20   
         label = 'Owner 2 full SSN / organisation ID (if party matches a customer)',
      account_08.account_in_basel_irb as account_in_account_exp length = 3,
      account_08.owner1_name length = 150   
         label = 'Primary owner´s name',
      account_08.owner2_name length = 150   
         label = 'Secondary owner´s name',
      EXCHANGE_RATES_EUR.mid_rate as exchange_rate_eur length = 8   
         format = 10.6
         label = 'Mid rate against eur',
      EXHANGE_RATES_SEK.mid_rate as exchange_rate_sek length = 8   
         format = 10.6
         label = 'Mid rate against sek',
      account_08.account_in_basel_irb length = 3,
      LIMIT.purpose_cd length = 5   
         label = 'Reason for limit code, eg. 6000',
      LIMIT.overdraft_interest_pct length = 8   
         format = 10.4
         label = 'Overdraft interest rate %',
      credit_in_default.create_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'The date when the default record was added. Part of key with the account_id.',
      lifetime_llg_par._NAME_ length = 23,
      lifetime_llg_par._LABEL_ length = 55,
      lifetime_llg_par.end_date_missing_ph_lo length = 8   
         format = 15.6,
      lifetime_llg_par.end_date_missing_ph_li length = 8   
         format = 15.6,
      lifetime_llg_par.end_date_missing_ph_gu length = 8   
         format = 15.6,
      lifetime_llg_par.end_date_missing_ph_dl length = 8   
         format = 15.6,
      lifetime_llg_par.end_date_missing_fx_lo length = 8   
         format = 15.6,
      lifetime_llg_par.end_date_missing_fx_li length = 8   
         format = 15.6,
      lifetime_llg_par.end_date_missing_fx_gu length = 8   
         format = 15.6,
      QUALITATIVE_JUDGEMENT_AGGR.judgement_id length = 4   
         format = 10.
         label = 'Qualitative judgment record id.',
      QUALITATIVE_JUDGEMENT_AGGR.owner_id length = 9   
         label = 'CBS customer number',
      QUALITATIVE_JUDGEMENT_AGGR.expire_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Qualitative judgement expiry date',
      EXCHANGE_RATES_EUR.mid_rate length = 8   
         format = 10.6
         label = 'Mean value of one base currency unit in currency (värdet på basvalutan i valutan)',
      stage_llg.stage_previous length = 3   
         format = 3.
         label = 'Forra stadie (1, 2 eller 3)',
      stage_llg.waiting_period_previous length = 8   
         format = 8.
         label = 'Förra karenstid (tiden som krediten måste stanna i det givna stadiet innan den får flytta till ett bättre stadie)',
      stage_llg.pd_initial_12m length = 8   
         format = 15.5
         label = 'Point in time 12-månaders PD-värde (sannolikheten för fallissemang inom det kommande året)',
      calculated_end_date_fixed.calculated_end_date_fixed length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'If calculated_end_date missing, then fixed value',
      loan_additional_data.external_application_id length = 64   
         label = 'Credit origination application id.',
      loan_application.application_pd as uc_pd_class_value length = 8   
         format = 18.5
         label = 'Applications probability of default',
      cust_cred_lvl.number_of_days as owner1_nbr_of_days length = 8,
      cust_cred_lvl_2.number_of_days as owner2_nbr_of_days length = 8,
      loan_additional_data.loan_cancellation_date length = 4   
         format = FINDFDD10.
         label = 'Loan cancellation date'
   from
      work.account_08 as account_08 left join 
      work.basel_irb as basel_irb
         on
         (
            account_08.information_date = basel_irb.information_date
            and account_08.bank_id = basel_irb.bank_id
            and account_08.account_id = basel_irb.account_id
         ) left join 
      work.loan_additional_data as loan_additional_data
         on
         (
            account_08.information_date = loan_additional_data.information_date
            and account_08.bank_id = loan_additional_data.bank_id
            and account_08.account_id = loan_additional_data.account_id
         ) left join 
      work.BANK_GUARANTEE as BANK_GUARANTEE
         on
         (
            account_08.information_date = BANK_GUARANTEE.information_date
            and account_08.bank_id = BANK_GUARANTEE.bank_id
            and account_08.account_id = BANK_GUARANTEE.account_id
            and loan_additional_data.information_date = BANK_GUARANTEE.information_date
         ) left join 
      work.LIMIT as LIMIT
         on
         (
            account_08.information_date = LIMIT.information_date
            and account_08.bank_id = LIMIT.bank_id
            and account_08.account_id = LIMIT.account_id
         ) left join 
      work.balance_average as balance_average
         on
         (
            account_08.information_date = balance_average.information_date
            and account_08.bank_id = balance_average.bank_id
            and account_08.account_id = balance_average.account_id
         ) left join 
      work.credit_in_default as credit_in_default
         on
         (
            account_08.information_date = credit_in_default.information_date
            and account_08.bank_id = credit_in_default.bank_id
            and account_08.account_id = credit_in_default.account_id
         ) left join 
      work.risk_customer_company as risk_customer_company
         on
         (
            account_08.information_date = risk_customer_company.information_date
            and account_08.bank_id = risk_customer_company.bank_id
            and account_08.owner1_id = risk_customer_company.customer_id
            and credit_in_default.information_date = risk_customer_company.information_date
         ) left join 
      work.account_25 as account_25
         on
         (
            account_08.information_date = account_25.information_date
            and account_08.bank_id = account_25.bank_id
            and account_08.account_id = account_25.account_id
         ) left join 
      work.lifetime_llg_par as lifetime_llg_par
         on
         (
            lifetime_llg_par._NAME_ = "parameter_value_decimal"
         ) left join 
      work.QUALITATIVE_JUDGEMENT_AGGR as QUALITATIVE_JUDGEMENT_AGGR
         on
         (
            account_08.information_date = QUALITATIVE_JUDGEMENT_AGGR.information_date
            and account_08.owner1_id = QUALITATIVE_JUDGEMENT_AGGR.owner_id
            and account_08.bank_id = QUALITATIVE_JUDGEMENT_AGGR.bank_id
         ) left join 
      work.EXCHANGE_RATES_EUR as EXCHANGE_RATES_EUR
         on
         (
            account_08.information_date = EXCHANGE_RATES_EUR.information_date
            and account_08.currency_cd = EXCHANGE_RATES_EUR.currency_cd
         ) left join 
      work.EXHANGE_RATES_SEK as EXHANGE_RATES_SEK
         on
         (
