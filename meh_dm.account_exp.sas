proc sql;
   create table work.account_03 as
   select
      account_daily.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Information date of the record',
      account_daily.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      account_daily.account_id length = 20   
         label = 'Account Number',
      account_daily.booked_balance_amt length = 8   
         format = 15.2
         label = 'Booked Balance,Amount 15,2 (2 decimals)',
      account_daily.credit_ref_interest_cd length = 10   
         label = 'Credit : Reference interest code',
      account_daily.credit_interest_rate_pct length = 8   
         format = 8.4
         label = 'Credit: Interest rate (today). Ref.rate + Margin',
      account_daily.credit_margin_rate_pct length = 8   
         format = 8.4
         label = 'Credit: Margin rate (today) - Customer marginal.',
      account_daily.interest_start_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Interest period From date',
      account_daily.interest_end_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Interest period To date',
      account_daily.credit_interest_estimate_amt length = 8   
         format = 15.2
         label = 'Interest estimated - Credit',
      account_daily.credit_interest_accrued_amt length = 8   
         format = 15.2
         label = 'Interest accrued - Credit',
      account_before_where.account_number_official length = 20   
         label = 'Account Number, official, In Finland this field is same as ACCNBR, in Sweden it contains the official Swedish account number.',
      account_before_where.account_type_cd length = 3   
         label = 'CBS Account Type',
      account_before_where.currency_cd length = 3   
         label = 'Account Currency',
      account_before_where.owner_id length = 9   
         label = 'CBS Customer ID. Account owner',
      account_before_where.owner_ssn_id length = 20   
         label = 'Social Sec.number / Org.number. Account owner',
      account_before_where.opened_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Account opened date'
   from
      work.account_daily as account_daily left join 
      work.account_before_where as account_before_where
         on
         (
            account_daily.information_date = account_before_where.information_date
            and account_daily.bank_id = account_before_where.bank_id
            and account_daily.account_id = account_before_where.account_id
         )
   where
      not account_before_where.account_type_cd = '380'
   ;
quit;

