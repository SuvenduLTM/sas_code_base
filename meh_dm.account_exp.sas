proc sql;
  create table DEF_ACC as 
  select d.bank_id, accCred.account_id, d.credit_id 
  from dwh_dw.CREDIT_DEFAULT_NON_PERF (where=(information_Date = &active_date.))as D left join 
       dwh_dw.account_credit_link as accCred 
  on D.bank_id=accCred.bank_id and D.credit_id=accCred.credit_id
     and D.information_date=accCred.Information_date  
  ;
quit;

proc sql;
  create table ALL_CREDITS as
  select bank_id, account_id, credit_id
  from DEF_ACC /*dwh_dw.CREDIT_DEFAULT_NON_PERF*/
  union 
  select bank_id, account_id, credit_id
  from max_due_dates /*work.WFHGCQ8*/;
quit;

proc sql;
  create table DEF_DUE as
  select &active_date. as information_date, 
         A.bank_id,  
         A.account_id,
         A.credit_id,
         DUE.number_of_days1, 
         DUE.number_of_days2,
         DEF.default_start_date, 
         DEF.default_end_date, 
         DEF.default_reason_txt,
         DEF.credit_id as np_credit_id
  from ALL_CREDITS A
       left join dwh_dw.CREDIT_DEFAULT_NON_PERF as DEF
	   on A.bank_id=DEF.bank_id and a.credit_id=DEF.credit_id and DEF.information_date = &active_date. 
	   left join max_due_dates as DUE
	   on A.bank_id=DUE.bank_id and a.credit_id=DUE.credit_id;
quit;

proc sql;
  create table M12 as
  select D.information_date, 
         D.bank_id,  
         D.account_id,
         D.credit_id,
         D.number_of_days1, 
         D.number_of_days2,
         D.default_start_date, 
         D.default_end_date, 
         D.default_reason_txt,
         D.np_credit_id,
         M.months_with_due_12mth
  from DEF_DUE as D left join MONTHS_WITH_DUE_12MTH as M
       on D.credit_id=M.credit_id; 
  *behöver ej joina på info date - båda tabellerna innehåller senaste*;
quit;


proc sql;
  create table NEW_DEF_HANDLING as
  select distinct M.information_date, 
         M.bank_id,  
         M.account_id,
         M.credit_id,
         M.number_of_days1, 
         M.number_of_days2,
         M.default_start_date, 
         M.default_end_date, 
         M.default_reason_txt,
         M.np_credit_id,
         M.months_with_due_12mth,
         E.EXPOSURE_AT_DEFAULT
  from m12 as M left join EAD_ONALL as E
       on M.credit_id=E.credit_id ; 
quit;


