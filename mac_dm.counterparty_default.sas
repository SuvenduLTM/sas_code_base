proc datasets lib = work nolist nowarn memtype = (data view);
   delete account_default;
quit;

proc sql;
   create view work.account_default as
   select distinct
      basel_irb.information_date length = 4   
         format = FINDFDD10.
         label = 'Information date of the record',
      basel_irb.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      basel_irb.account_id length = 20   
         label = 'Account number / Credit number / Loan number',
      cat(account.bank_id, account.owner_id) as counterparty_identifier length = 60   
         label = 'Counterparty Identifier',
      customer.name length = 150   
         label = 'Customer Name (All customers)',
      credit_in_default.default_reason_cd length = 3   
         label = 'Default reason code',
      credit_in_default.default_start_date length = 4   
         format = FINDFDD10.
         label = 'Default begin date'
   from
      work.basel_irb as basel_irb left join 
      work.account as account
         on
         (
            basel_irb.information_date = account.information_date
            and basel_irb.bank_id = account.bank_id
            and basel_irb.account_id = account.account_id
         ) left join 
      work.customer as customer
         on
         (
            account.information_date = customer.information_date
            and account.bank_id = customer.bank_id
            and account.owner_id = customer.customer_id
         ) left join 
      work.credit_in_default as credit_in_default
         on
         (
            basel_irb.information_date = credit_in_default.information_date
            and basel_irb.bank_id = credit_in_default.bank_id
            and basel_irb.account_id = credit_in_default.account_id
         ) left join 
      work.par_code_converter as par_code_converter
         on
         (
            credit_in_default.information_date = par_code_converter.information_date
            and credit_in_default.default_reason_cd = par_code_converter.internal_value_char
            and credit_in_default.bank_id = par_code_converter.bank_id
         )
   where
      basel_irb.pd_class_number = 11
      and basel_irb.irb_exposure_class IN (3,4,5)
      and credit_in_default.default_start_date NOT IS MISSING 
      and credit_in_default.default_end_date IS MISSING 
      and par_code_converter.code_type = 'CL_CRDT_QLTY_DFLT_STTS_AC'
      and par_code_converter.target_table = 'COUNTERPARTY_DEFAULT'
   ;
quit;

