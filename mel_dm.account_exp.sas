proc sql;
   create table work.customer_01 as
   select
      account_28.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      account_28.account_id length = 20   
         label = 'Account Number (=key filed to other Account databases). Same format in both Finland and Sweden',
      account_28.owner1_id length = 9   
         label = 'CBS Customer ID. Account owner',
      account_28.booked_balance_amt length = 8   
         label = 'Booked Balance,Amount 15,2 (2 decimals)',
      account_28.owner1_ssn_id length = 20   
         label = 'Social security / organisation number',
      account_28.customer_type length = 8   
         label = '1=Private, 2=Coorp.cust.',
      account_28.owner2_ssn_id length = 20   
         label = 'Social security / organisation number',
      account_28.pd_class_number length = 8   
         label = 'Probability default class number',
      account_28.unmanaged_days_max_cnt length = 8   
         label = 'Max number of days the loan has been unmanaged during the month.',
      account_28.max_limit_amt length = 8   
         label = 'Maximum amount usable during the month',
      account_28.overdraft_days_max_cnt length = 3   
         label = 'Maximum number of days overdrawn, from RISK system',
      account_28.balance_average_amt length = 8   
         label = 'Monthly average balance',
      case 
        when account_28.balance_average_amt<0 and account_28.max_limit_amt =.  then 0 
        when account_28.balance_average_amt>=0  then 0
        when account_28.balance_average_amt<0 and account_28.max_limit_amt ne . and sum(account_28.balance_average_amt ,abs(account_28.max_limit_amt))<0 then abs(account_28.max_limit_amt)
        when account_28.balance_average_amt<0 and account_28.max_limit_amt ne . and sum(account_28.balance_average_amt , abs(account_28.max_limit_amt))>=0 then sum(0,-account_28.balance_average_amt)
        else . 
      end as used_limit_amt length = 8   
         label = 'used_limit_amount',
      case 
       when account_28.balance_average_amt<0 and account_28.max_limit_amt =. then 0
       when account_28.balance_average_amt>=0 then 0
       when account_28.balance_average_amt<0 and account_28.max_limit_amt ne . and sum(account_28.balance_average_amt ,abs(account_28.max_limit_amt) )<0 then sum(0,-account_28.balance_average_amt,account_28.max_limit_amt )
       when account_28.balance_average_amt<0 and account_28.max_limit_amt ne . and sum(account_28.balance_average_amt , abs(account_28.max_limit_amt) )>=0 then 0
        else . 
      end as avg_overdrawn_amt length = 8   
         label = 'average_overdrawn_amount',
      case 
       when account_28.balance_average_amt<0 and account_28.max_limit_amt =. then account_28.balance_average_amt
       when account_28.balance_average_amt>=0 then account_28.balance_average_amt
       when account_28.balance_average_amt<0 and account_28.max_limit_amt ne .
         and sum(account_28.balance_average_amt ,account_28.max_limit_amt )<0 then 0
       when account_28.balance_average_amt<0 and account_28.max_limit_amt ne .
         and sum(account_28.balance_average_amt , account_28.max_limit_amt )>=0 then 0
        else . 
      end as avg_deposit_balance length = 8   
         label = 'average_deposit_balance',
      case when substr(account_28.account_type_cd,1,1) ne '8' then 0 else account_28.booked_balance_amt end as owner1_booked_balance_amt length = 8   
         label = 'Summarized booked balance over owner1_ssn_id',
      case when account_28.balance_average_amt < 0 then account_28.balance_average_amt else . end as exposure_balance_avg_amt length = 8   
         label = 'Average exposure balance amount for the account (if negative, otherwise missing)',
      account_28.account_in_account_exp length = 3,
      case when INTCK('month', &active_date., account_28.initial_date,'d')=0 then 1 else 0 end as new_credit_flg length = 4   
         label = 'If initial_date is from the current month, the flag should be set ''1'', else ''0''.'
   from
      work.account_28 as account_28
   ;
quit;

