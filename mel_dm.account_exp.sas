proc sql;
   create view work.W538V8D as
   select
      ACCOUNT_CREDIT_LINK.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'The date for the information in the current file yyyyMMdd',
      ACCOUNT_CREDIT_LINK.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden, C=Borgo',
      ACCOUNT_CREDIT_LINK.credit_id length = 8   
         format = 15.
         label = 'Credit ID (internal)',
      ACCOUNT_CREDIT_LINK.account_id length = 14   
         label = 'Account number (internal)',
      max(CREDIT_DUE_AMT_CREDIT_LVL.number_of_days1) as number_of_days1 length = 5   
         format = 5.
         label = 'Number of material due days. Considers the technical status.'
   from
      dw_dw.CREDIT_DUE_AMT_CREDIT_LVL
      (
         &altercommand.
      ) as CREDIT_DUE_AMT_CREDIT_LVL, 
      dw_dw.ACCOUNT_CREDIT_LINK
      (
         &altercommand.
      ) as ACCOUNT_CREDIT_LINK
   where
      intnx('Month',CREDIT_DUE_AMT_CREDIT_LVL.information_date,0,'E') = intnx('Month', ACCOUNT_CREDIT_LINK.information_date, 0,'E')
      and CREDIT_DUE_AMT_CREDIT_LVL.bank_id = ACCOUNT_CREDIT_LINK.bank_id
      and CREDIT_DUE_AMT_CREDIT_LVL.credit_id = ACCOUNT_CREDIT_LINK.credit_id
      and CREDIT_DUE_AMT_CREDIT_LVL.information_date BETWEEN intnx('month',&active_date.,0,'b') and &active_date
   group by
      ACCOUNT_CREDIT_LINK.account_id
   ;
quit;

