         (case 
            when (bank_id='B' and customer_type=2) then 'SWEDEN_CORPORATE'
            when (bank_id='B' and customer_type=1) then 'SWEDEN_PRIVATE' 
            when (bank_id='A' and customer_type=2) then 'FINLAND_CORPORATE' 
            when (bank_id='A' and customer_type=1) then 'FINLAND_PRIVATE' 
            else ' ' end) as pd_adjustment_group_id length = 20
            label = 'Customer grouping for PD adjustments',
         owner1_legal_form_cd,
         owner2_legal_form_cd   
            label = 'Juridisk Form',
