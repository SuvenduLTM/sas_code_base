proc datasets lib = work nolist nowarn memtype = (data view);
   delete account_basel;
quit;

proc sql;
   create table work.account_basel as
   select distinct
      coalesce(basel_irb.information_date,basel_sa.information_date) as information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Information date of the record',
      coalesce(basel_irb.bank_id,basel_sa.bank_id) as bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      coalesce(basel_irb.account_id,basel_sa.account_id) as account_id length = 20   
         label = 'Account number / Credit number / Loan number',
      case basel_irb.account_id when "" then 0 else 1 end as account_in_basel_irb length = 3,
      case basel_sa.account_id when "" then 0 else 1 end as account_in_basel_sa length = 3
   from
      work.basel_sa as basel_sa full join 
      work.basel_irb as basel_irb
         on
         (
            basel_sa.information_date = basel_irb.information_date
            and basel_sa.bank_id = basel_irb.bank_id
            and basel_sa.account_id = basel_irb.account_id
         )
   ;
quit;

