proc sql;
   create table work.account_08 as
   select distinct
      account_05.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Information date of the record',
      account_05.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      account_05.account_id length = 20   
         label = 'Account Number',
      account_05.booked_balance_amt length = 8   
         format = 15.2
         label = 'Booked Balance,Amount 15,2 (2 decimals)',
      account_05.credit_ref_interest_cd length = 10   
         label = 'Credit : Reference interest code',
      account_05.credit_interest_rate_pct length = 8   
         format = 8.4
         label = 'Credit: Interest rate (today). Ref.rate + Margin',
      account_05.credit_margin_rate_pct length = 8   
         format = 8.4
         label = 'Credit: Margin rate (today) - Customer marginal.',
      account_05.interest_start_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Interest period From date',
      account_05.interest_end_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Interest period To date',
      account_05.credit_interest_estimate_amt length = 8   
         format = 15.2
         label = 'Interest estimated - Credit',
      account_05.credit_interest_accrued_amt length = 8   
         format = 15.2
         label = 'Interest accrued - Credit',
      account_05.account_number_official length = 20   
         label = 'Account Number, official, In Finland this field is same as ACCNBR, in Sweden it contains the official Swedish account number.',
      account_05.account_type_cd length = 3   
         label = 'CBS Account Type',
      account_05.currency_cd length = 3   
         label = 'Account Currency',
      account_05.owner1_id length = 9   
         label = 'CBS Customer ID. Account owner',
      account_05.owner2_id length = 9   
         label = 'CBS Customer ID. Account owner 2',
      account_05.opened_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Account opened date',
      customer1.customer_id length = 9   
         label = 'CBS Customer ID',
      customer1.ssn_id as owner1_ssn_id length = 20   
         label = 'Social security / organisation number',
      customer2.ssn_id as owner2_ssn_id length = 20   
         label = 'Secondary owner´s social security / organisation number',
      customer1.customer_type length = 3   
         format = 3.
         label = '1=Private, 2=Coorp.cust.',
      case when customer1.birth_date = . then . else YRDIF(customer1.birth_date, account_05.information_date, 'ACT/ACT') end as owner1_age length = 8   
         format = 15.2
         informat = 15.2
         label = 'Primary owner´s age in years',
      case when customer2.birth_date = . then . else YRDIF(customer2.birth_date, account_05.information_date, 'ACT/ACT') end as owner2_age length = 8   
         format = 15.2
         informat = 15.2
         label = 'Secondary owner´s age in years',
      customer1.gender_cd as owner1_gender_cd length = 3   
         format = 3.
         label = 'Gender: 0 = Company, 1 =Male, 2 = Female',
      customer2.gender_cd as owner2_gender_cd length = 3   
         format = 3.
         label = 'Secondary owner´s gender: 0 = Company, 1 =Male, 2 = Female',
      customer1.post_office_number length = 10   
         label = 'Post office number',
      customer1.name as owner1_name length = 150   
         label = 'Primary owner´s name',
      customer2.name as owner2_name length = 150   
         label = 'Secondary owner´s name',
      customer1.country_cd length = 2   
         label = 'Address-country code',
      customer1.result_office_id length = 2   
         label = 'Customers office-number',
      customer1.legal_form_cd as owner1_legal_form_cd length = 2   
         label = 'Juridisk Form',
      customer2.legal_form_cd as owner2_legal_form_cd length = 2   
         label = 'Secondary owner´s legal form',
      customer1.stat_sector_cd length = 6   
         label = 'Sektorkod. Obs : 6 siffror.',
      customer1.stat_branch_cd length = 6   
         label = 'Näringsgren. Obs: 6 siffror i kundreg. Ngrenkp färre siffror (fyll ut med nollor)',
      customer1.trade_register_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Registration date for Trade Register of corporate customer  (Reg.datum Handels/Föreningsregister)',
      customer1.capital_coverage_cd length = 4   
         label = 'Coverage (Kapitaltäckning), only used for corporate customers',
      party1.party_ssn_id as owner1_party_ssn_id length = 20   
         label = 'Owner 1 full SSN / organisation ID (if party matches a customer)',
      party2.party_ssn_id as owner2_party_ssn_id length = 20   
         label = 'Owner 2 full SSN / organisation ID (if party matches a customer)',
      case when (account_basel.account_in_basel_irb or account_basel.account_in_basel_sa) then 1 else 0 end as account_in_basel_irb length = 3
   from
      work.account_05 as account_05 left join 
      work.customer as customer1
         on
         (
            account_05.information_date = customer1.information_date
            and account_05.bank_id = customer1.bank_id
            and account_05.owner1_id = customer1.customer_id
         ) left join 
      work.customer as customer2
         on
         (
            account_05.information_date = customer2.information_date
            and account_05.bank_id = customer2.bank_id
            and account_05.owner2_id = customer2.customer_id
         ) left join 
      work.CUSTOMER_RELATED_PARTIES as party1
         on
         (
            account_05.information_date = party1.information_date
            and account_05.bank_id = party1.bank_id
            and customer1.ssn_id = party1.ssn_id
            and customer1.legal_form_cd = '11'
            and party1.party_rank = 1
            and party1.party_relation_cd = 'O'
         ) left join 
      work.CUSTOMER_RELATED_PARTIES as party2
         on
         (
            account_05.information_date = party2.information_date
            and account_05.bank_id = party2.bank_id
            and customer2.ssn_id = party2.ssn_id
            and customer2.legal_form_cd = '11'
            and party2.party_rank = 1
            and party2.party_relation_cd = 'O'
         ) left join 
      work.account_basel as account_basel
         on
         (
            account_05.information_date = account_basel.information_date
            and account_05.bank_id = account_basel.bank_id
            and account_05.account_id = account_basel.account_id
         )
   ;
quit;

