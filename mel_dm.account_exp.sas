proc datasets lib = work nolist nowarn memtype = (data view);
   delete sum_owners;
quit;

proc sql;
   create table work.sum_owners as
   select distinct
      customer_01.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      account_owners.owner_id length = 9   
         label = 'CBS Customer ID. Account owner',
      sum(customer_01.booked_balance_amt) as booked_balance_amt length = 8   
         label = 'Booked Balance,Amount 15,2 (2 decimals)',
      max(max(customer_01.unmanaged_days_max_cnt),.) as unmanaged_days_max_cnt length = 8   
         label = 'Max number of days the loan has been unmanaged during the month.',
      sum(customer_01.max_limit_amt) as max_limit_amt length = 8   
         label = 'Maximum amount usable during the month',
      max(max(customer_01.overdraft_days_max_cnt),.) as overdraft_days_max_cnt length = 3   
         label = 'Maximum number of days overdrawn, from RISK system',
      sum(min(0,customer_01.balance_average_amt)) as balance_average_amt length = 8   
         label = 'Monthly average balance',
      sum(customer_01.used_limit_amt) as used_limit_amt length = 8   
         label = 'used_limit_amount',
      sum(customer_01.avg_overdrawn_amt) as avg_overdrawn_amt length = 8   
         label = 'average_overdrawn_amount',
      sum(max(0,customer_01.avg_deposit_balance)) as avg_deposit_balance length = 8   
         label = 'average_deposit_balance',
      sum(customer_01.owner1_booked_balance_amt) as owner1_booked_balance_amt length = 8   
         label = 'Summarized booked balance over owner1_ssn_id',
      sum(min(0,customer_01.balance_average_amt)) as exposure_balance_avg_amt length = 8   
         label = 'Average exposure balance amount for the account (if negative, otherwise missing)',
      sum(customer_01.account_in_account_exp) as owner1_account_cnt length = 3   
         label = 'Count of accounts of owner1'
   from
      work.account_owners as account_owners, 
      work.customer_01 as customer_01
   where
      account_owners.bank_id = customer_01.bank_id
      and account_owners.account_id = customer_01.account_id
   group by
      customer_01.bank_id,
      account_owners.owner_id
   ;
quit;

