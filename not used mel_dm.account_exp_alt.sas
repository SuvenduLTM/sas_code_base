         label = 'Average exposure balance amount for the account (if negative, otherwise missing)',
      account_28.contractual_end_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Contractual end date (end_date for guaranties, loan_end_date for loans)',
      account_28.initial_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Initial date (changed_date for limits, account opened_date for loans and guaranties)',
      account_28.qa_pd_class_cd length = 4   
         format = 5.
         label = 'Qualitative judgement pd class number',
      counts.owner1_only_limits_flg length = 3   
         format = 3.
