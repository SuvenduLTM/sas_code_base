         label = 'Summarized average_overdrawn_amount over owner2_ssn_id',
      sum_owner2.avg_deposit_balance as owner2_deposit_balance_avg_amt length = 8   
         label = 'Summarized average_deposit_balance over owner2_ssn_id',
