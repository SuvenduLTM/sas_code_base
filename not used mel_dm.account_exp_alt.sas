      account_28.owner2_party_ssn_id length = 20   
         label = 'Owner 2 full SSN / organisation ID (if party matches a customer)',
      account_28.used_limit_amt length = 8   
         format = 15.2
         label = 'Limit amount, calculated, currently used'
   from
      work.account_basel as account_basel left join 
      work.account_28 as account_28
         on
         (
            account_basel.information_date = account_28.information_date
            and account_basel.bank_id = account_28.bank_id
            and account_basel.account_id = account_28.account_id
         ) left join 
      work.sum_owners as sum_owner1
         on
         (
            account_28.bank_id = sum_owner1.bank_id
            and account_28.owner1_id = sum_owner1.owner_id
         ) left join 
      work.sum_owners as sum_owner2
         on
         (
            account_28.bank_id = sum_owner2.bank_id
            and account_28.owner2_id = sum_owner2.owner_id
         ) left join 
      work.counts as counts
         on
         (
            account_28.bank_id = counts.bank_id
            and account_28.owner1_id = counts.owner1_id
         ) left join 
      work.prev_months_count as prev_months_count
         on
         (
            account_28.bank_id = prev_months_count.bank_id
            and account_28.account_id = prev_months_count.account_id
         )
   group by
      account_28.information_date,
      account_28.bank_id,
      account_28.account_id
   order by
      account_28.information_date,
      account_28.bank_id,
      account_28.account_id
   ;
quit;

