/*==========================================================================* 
 * Step:            inner join                            A5ZNM6KG.BS0003UG * 
 * Transform:       Join                                                    * 
 * Description:     + select the most recent records                        * 
 *                                                                          * 
 * Source Tables:   account_collateral_link -             A5ZNM6KG.BV00033L * 
 *                   work.account_collateral_link                           * 
 *                  collateral_object_link -              A5ZNM6KG.BV00033M * 
 *                   work.collateral_object_link                            * 
 *                  guarantee_object -                    A5ZNM6KG.BV00033N * 
 *                   work.guarantee_object                                  * 
 * Target Table:    GUARANTEE_OBJECT... - work.account_25 A5ZNM6KG.BV00033O * 
 *==========================================================================*/ 

%let transformID = %quote(A5ZNM6KG.BS0003UG);
%let trans_rc = 0;
%let etls_stepStartTime = %sysfunc(datetime(), datetime20.); 

%global etls_sql_pushDown;
%let etls_sql_pushDown = -1;
option DBIDIRECTEXEC;

proc datasets lib = work nolist nowarn memtype = (data view);
   delete account_25;
quit;

proc sql;
   create table work.account_25 as
   select distinct
      guarantee_object.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Information date of the record',
      guarantee_object.bank_id length = 1   
         label = 'Bank ID code: A = Ă…B Finland, B = Ă…B Sweden',
      account_collateral_link.account_id length = 20   
         label = 'Credit account number',
      sum(guarantee_object.guarantors_cnt ) as guarantors_cnt length = 4   
         format = 8.
         label = 'Number of guarantors'
   from
      work.account_collateral_link as account_collateral_link, 
      work.collateral_object_link as collateral_object_link, 
      work.guarantee_object as guarantee_object
   where
      account_collateral_link.bank_id = collateral_object_link.bank_id
      and account_collateral_link.bank_id = guarantee_object.bank_id
      and guarantee_object.internal_object_id = collateral_object_link.internal_object_id
      and collateral_object_link.internal_collateral_id = account_collateral_link.internal_collateral_id
      and (guarantee_object.expiry_date >= guarantee_object.information_date
      or guarantee_object.expiry_date = .)
   group by
      guarantee_object.information_date,
      guarantee_object.bank_id,
      account_collateral_link.account_id 
   ;
quit;

