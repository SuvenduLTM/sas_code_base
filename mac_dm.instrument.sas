option DBIDIRECTEXEC;

proc datasets lib = work nolist nowarn memtype = (data view);
   delete W28M9XWU;
quit;

proc sql;
   create view work.W28M9XWU as
   select distinct
      account_data.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Information date of the record',
      account_data.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      account_data.account_id length = 20   
         label = 'Account Number',
      account_data.account_number_official length = 20   
         label = 'Account number official, In Finland this field is same as ACCNBR, in Sweden it contains the official Swedish account number',
      account_data.account_type_cd length = 3   
         label = 'CBS Account Type',
      account_data.customer_id_mod length = 60   
         label = 'Modified customer identifier',
      account_data.name length = 150   
         label = 'Customer Name (all customers)',
      account_data.stat_sector_cd length = 6   
         label = 'Sektorkod. Obs : 6 siffror.',
      account_data.original_account_id length = 14   
         label = 'Credit account id before it was on collection. 0 is allowed',
      account_data.currency_cd length = 3   
         label = 'Account Currency code',
      account_data.mid_rate length = 8   
         format = 10.6
         label = 'Mean value of one base currency nit in currency',
      account_data.opened_date_mid_rate length = 8   
         format = 10.6
         label = 'Mean value of one base currency nit in currency on accounts opening date',
      account_data.booked_balance_amt length = 8   
         format = 15.2
         label = 'Booked balance amount',
      account_data.credit_ref_interest_cd length = 10   
         label = 'Credit: Reference interest code',
      account_data.credit_margin_rate_pct length = 8   
         format = 8.4
         label = 'Credit: Margin rate (today). Customer marginal',
      account_data.overdraft_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Overdraft day 1.',
      account_data.total_withdrawable_amount length = 8   
         format = 15.2
         label = 'Total withdrawable amount',
      account_data.original_loan_amount length = 8   
         format = 15.2
         label = 'The original loan amount that was granted',
      account_data.loan_end_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'The contractual loan end date',
      account_data.payment_plan_cd length = 1   
         label = 'Payment plan (0=No, 1=Fixed, 2=Annuity, 3=Straight amortization, 4=Bullet)',
      account_data.purpose_of_use_cd length = 4   
         label = 'The loans purpose of use',
      account_data.principal_payments_per_year_cnt length = 8   
         format = 2.
         label = 'Number of principal payments per year',
      account_data.next_principal_payment_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Next principal payment date',
      account_data.interest_cap_and_floor_type length = 1   
         label = 'Interest rate cap and floor type(1=Interest corridor,2=Interest rate cap, Empty=N/a, if type is 2 then the floor rate percent is not in use)',
      account_data.interest_cap_n_floor_start_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Interest corridor start date',
      account_data.interest_cap_n_floor_end_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Interest corridor end date',
      account_data.interest_cap_n_floor_f_rate_pct length = 8   
         format = 8.4
         label = 'Interest corridor floor rate',
      account_data.interest_cap_n_floor_c_rate_pct length = 8   
         format = 8.4
         label = 'Interest corridor ceiling rate',
      account_data.current_limit_amt length = 8   
         format = 15.2
         label = 'Current limit amount',
      account_data.expiry_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Limit expiry date',
      account_data.opened_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Account opened date',
      account_data.changed_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Account changed date',
      account_data.close_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Account close date',
      basel_irb.irb_exposure_class length = 3   
         format = 2.
         label = 'IRB exposure class'
   from
      work.account_data as account_data left join 
      work.basel_irb as basel_irb
         on
         (
            account_data.information_date = basel_irb.information_date
            and account_data.bank_id = basel_irb.bank_id
            and account_data.account_id = basel_irb.account_id
         )
   where
      account_data.exposures_amt > 0
      or (account_data.booked_balance_amt_prev_month NOT IS MISSING 
      and account_data.booked_balance_amt_prev_month < 0)
   ;
quit;

