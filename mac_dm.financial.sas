        " observed_agent_identifier, contract_identifier,   "
        " instrument_identifier, interest_rate, next_interest_reset_date,   "
        " default_status_instrument, default_status_instrument_date,"
        " transferred_amt,    arrears_for_the_instrument,"
        " date_of_past_due_for_instrument,    type_of_securitisation,"
        " outstanding_nominal_amt, accrued_interest,    off_balance_sheet_amt";
run;

%put %str(NOTE: Mapping columns ...);
proc sql;
   create view work.W1E9UMHW as
      select
         information_date,
         "" as reporting_agent_identifier length = 60
            label = 'Reporting agent identifier',
         "" as observed_agent_identifier length = 60
            label = 'Observed agent identifier',
         "" as contract_identifier length = 60
            label = 'Contract identifier',
         "" as instrument_identifier length = 60
            label = 'Instrument identifier',
         . as interest_rate length = 8
            format = 15.4
            label = 'Interest rate',
         . as next_interest_reset_date length = 8
            format = findfdd10.
            label = 'Next interest rate reset date',
         "" as default_status_instrument length = 3
            label = 'Default status of the instrument',
         . as default_status_instrument_date length = 8
            format = findfdd10.
            label = 'Date of the default status of the instrument',
         . as transferred_amt length = 8
            format = 15.2
            label = 'Transferred amount',
         . as arrears_for_the_instrument length = 8
            format = 15.2
            label = 'Arrears for the instrument',
         . as date_of_past_due_for_instrument length = 8
            format = findfdd10.
            label = 'Date of past due for the instrument',
         "" as type_of_securitisation length = 1
            label = 'Type of securitisation',
         . as outstanding_nominal_amt length = 8
            format = 15.2
            label = 'Outstanding nominal amount',
         . as accrued_interest length = 8
            format = 15.2
            label = 'Accrued interest',
         . as off_balance_sheet_amt length = 8
            format = 15.2
            label = 'Off-balance-sheet amount',
         bank_id,
         account_id,
         account_number_official,
         original_account_id,
         account_type_cd,
         customer_id_mod,
         name,
         credit_interest_rate_pct,
         credit_margin_rate_pct,
         next_interest_change_date,
         default_reason_cd,
         default_start_date,
         ledger_amt,
         actual_due_date,
         loan_end_date,
         currency_cd,
         mid_rate,
         booked_balance_amt,
         current_limit_amt,
         expiry_date,
         total_withdrawable_amount,
         interest_amt,
         shared,
         (%sysfunc(round(%sysfunc(datetime()),1))) as loaded_dt length = 8
            format = DATETIME20.
            label = 'Load timestamp (date & time)'
   from &SYSLAST
      where exposures_amt > 0 OR ( booked_balance_amt_prev_month NOT IS MISSING AND booked_balance_amt_prev_month  < 0 )
   ;
quit;

