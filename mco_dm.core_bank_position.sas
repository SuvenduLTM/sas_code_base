%global etls_sql_pushDown;
%let etls_sql_pushDown = -1;
option DBIDIRECTEXEC;

proc datasets lib = work nolist nowarn memtype = (data view);
   delete account_3;
quit;

proc sql;
   create table work.account_3 as
   select
      account_daily.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Information date of the record',
      account_daily.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      account_daily.account_id length = 20   
         label = 'Account Number (=key filed to other Account databases). Same format in both Finland and Sweden',
      account.account_number_official length = 20   
         label = 'Account Number, official, In Finland this field is same as ACCNBR, in Sweden it contains the official Swedish account number.',
      account.account_type_cd length = 3   
         label = 'CBS Account Type',
      account.currency_cd length = 3   
         label = 'Account Currency',
      account.owner_id length = 9   
         label = 'CBS Customer ID. Account owner',
      account.owner_ssn_id length = 20   
         label = 'Social Sec.number / Org.number. Account owner',
      account.opened_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Account opened date',
      account.changed_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Account changed date',
      account.end_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Account end date. Filled in the day when the account is closed. Other days empty. Always empty at this moment. Not defined how to use this field.',
      account.close_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Account closed date',
      account.group_account_id length = 20   
         label = 'Group Account Number (next level up)',
      account_daily.booked_balance_amt length = 8   
         format = 15.2
         label = 'Booked Balance,Amount 15,2 (2 decimals)',
      account_daily.debit_ref_interest_cd length = 10   
         label = 'Debit : Reference interest code',
      account_daily.debit_interest_rate_pct length = 8   
         format = 8.4
         label = 'Debit: Interest rate (today) Ref.rate + Margin.',
      account_daily.debit_margin_rate_pct length = 8   
         format = 8.4
         label = 'Debit: Margin rate (today) - Customer marginal',
      account_daily.credit_ref_interest_cd length = 10   
         label = 'Credit : Reference interest code',
      account_daily.credit_interest_rate_pct length = 8   
         format = 8.4
         label = 'Credit: Interest rate (today). Ref.rate + Margin',
      account_daily.credit_margin_rate_pct length = 8   
         format = 8.4
         label = 'Credit: Margin rate (today) - Customer marginal.',
      account_daily.interest_start_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Interest period From date',
      account_daily.interest_end_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Interest period To date',
      account_daily.debit_interest_estimate_amt length = 8   
         format = 15.2
         label = 'Interest estimated - Debit',
      account_daily.credit_interest_estimate_amt length = 8   
         format = 15.2
         label = 'Interest estimated - Credit',
      account_daily.debit_interest_accrued_amt length = 8   
         format = 15.2
         label = 'Interest accrued - Debit',
      account_daily.credit_interest_accrued_amt length = 8   
         format = 15.2
         label = 'Interest accrued - Credit',
      account_daily.debit_interest_calc_cd length = 2   
         label = 'Debit Interest Calculation Method (360, 365, ...)',
      account_daily.credit_interest_calc_cd length = 2   
         label = 'Credit Interest Calculation Method (360, 365, ...)',
      account_daily.source_system_cd length = 3   
         label = 'Data source system'
   from
      work.account as account right join 
      work.account_daily as account_daily
         on
         (
            account.bank_id = account_daily.bank_id
            and account.account_id = account_daily.account_id
         )
   where
      account.information_date = account_daily.information_date
   ;
quit;

