proc sql;
   create table work.ACCOUNT_9 as
   select distinct
      account_7.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Information date of the record',
      account_7.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      account_7.account_id length = 20   
         label = 'Account Number (=key filed to other Account databases). Same format in both Finland and Sweden',
      account_7.account_number_official length = 20   
         label = 'Account Number, official, In Finland this field is same as ACCNBR, in Sweden it contains the official Swedish account number.',
      account_7.account_type_cd length = 3   
         label = 'CBS Account Type',
      account_7.currency_cd length = 3   
         label = 'Account Currency',
      account_7.owner_id length = 9   
         label = 'CBS Customer ID. Account owner',
      account_7.owner_ssn_id length = 20   
         label = 'Social Sec.number / Org.number. Account owner',
      account_7.opened_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Account opened date',
      account_7.changed_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Account changed date',
      account_7.end_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Account end date. Filled in the day when the account is closed. Other days empty. Always empty at this moment. Not defined how to use this field.',
      account_7.close_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Account closed date',
      account_7.group_account_id length = 20   
         label = 'Group Account Number (next level up)',
      account_7.booked_balance_amt length = 8   
         format = 15.2
         label = 'Booked Balance,Amount 15,2 (2 decimals)',
      account_7.debit_ref_interest_cd length = 10   
         label = 'Debit : Reference interest code',
      account_7.debit_interest_rate_pct length = 8   
         format = 8.4
         label = 'Debit: Interest rate (today) Ref.rate + Margin.',
      account_7.debit_margin_rate_pct length = 8   
         format = 8.4
         label = 'Debit: Margin rate (today) - Customer marginal',
      account_7.credit_ref_interest_cd length = 10   
         label = 'Credit : Reference interest code',
      account_7.credit_interest_rate_pct length = 8   
         format = 8.4
         label = 'Credit: Interest rate (today). Ref.rate + Margin',
      account_7.credit_margin_rate_pct length = 8   
         format = 8.4
         label = 'Credit: Margin rate (today) - Customer marginal.',
      account_7.interest_start_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Interest period From date',
      account_7.interest_end_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Interest period To date',
      account_7.debit_interest_estimate_amt length = 8   
         format = 15.2
         label = 'Interest estimated - Debit',
      account_7.credit_interest_estimate_amt length = 8   
         format = 15.2
         label = 'Interest estimated - Credit',
      account_7.debit_interest_accrued_amt length = 8   
         format = 15.2
         label = 'Interest accrued - Debit',
      account_7.credit_interest_accrued_amt length = 8   
         format = 15.2
         label = 'Interest accrued - Credit',
      account_7.debit_interest_calc_cd length = 2   
         label = 'Debit Interest Calculation Method (360, 365, ...)',
      account_7.credit_interest_calc_cd length = 2   
         label = 'Credit Interest Calculation Method (360, 365, ...)',
      account_7.source_system_cd length = 3   
         label = 'Data source system',
      account_7.ssn_id length = 20   
         label = 'Social security / organisation number',
      account_7.customer_type length = 3   
         format = 3.
         label = '1=Private, 2=Coorp.cust.',
      account_7.name length = 150   
         label = 'Customer Name (All customers)',
      account_7.person_last_name length = 50   
         label = 'Last name. Corp.customer = blanks',
      account_7.person_first_name length = 50   
         label = 'First name. Corp.customer = blanks',
      account_7.country_cd length = 2   
         label = 'Address-country code',
      account_7.municipality_cd length = 3   
         label = 'Municipality code',
      account_7.result_office_id length = 2   
         label = 'Customers office-number',
      account_7.citizenship_cd length = 2   
         label = 'Citizenship code',
      account_7.legal_form_cd length = 2   
         label = 'Juridisk Form',
      account_7.stat_sector_cd length = 6   
         label = 'Sektorkod. Obs : 6 siffror.',
      account_7.stat_branch_cd length = 6   
         label = 'Näringsgren. Obs: 6 siffror i kundreg. Ngrenkp färre siffror (fyll ut med nollor)',
      account_7.issue_country_cd length = 2   
         label = 'Issue country for ID',
      account_7.sm_risk_weight_pct length = 8   
         format = 10.7
         label = 'S-method risk weight percentage',
      account_7.exposure_amount length = 8   
         format = 15.2
         label = 'Exposure amount',
      case 
        when max(ESTABLISHED_CUSTOMER.stat_sector_cd) eqt '122' then '6' 
        else max(ESTABLISHED_CUSTOMER.customer_group_cd)
      end as customer_group_cd length = 1   
         label = 'Customer group code: 1, 2, 3, 4, 5',
      ESTABLISHED_CUSTOMER.guaranteed length = 3   
         format = 3.
         label = 'Guaranteed: 1=Yes, 0=No, .=unknown',
      max(ESTABLISHED_CUSTOMER.established) as established length = 3   
         format = 3.
         label = 'Established: 1=Yes, 0=No, .=unknown',
      EXCHANGE_RATES.mid_rate length = 8   
         format = 10.6
         label = 'Mean value of one base currency unit in currency (värdet på basvalutan i valutan)',
      case
        when EXCHANGE_RATES.mid_rate=0 then . 
        when sum(ESTABLISHED_CUSTOMER.sum_total_amt/EXCHANGE_RATES.mid_rate) le 0 then 0 
        else 100000*ESTABLISHED_CUSTOMER.sum_total_amt
                *ESTABLISHED_CUSTOMER.guaranteed
                 /EXCHANGE_RATES.mid_rate
                 /sum(ESTABLISHED_CUSTOMER.sum_total_amt     
                 *ESTABLISHED_CUSTOMER.guaranteed/EXCHANGE_RATES.mid_rate)
      end as share_of_guaranteed_amt length = 8   
         format = 15.2
         label = 'Shrare of guaranteed amoung (calculated value)'
   from
      work.account_7 as account_7 left join 
      work.ESTABLISHED_CUSTOMER as ESTABLISHED_CUSTOMER
         on
         (
            account_7.information_date = ESTABLISHED_CUSTOMER.information_date
            and account_7.bank_id = ESTABLISHED_CUSTOMER.bank_id
            and account_7.account_id = ESTABLISHED_CUSTOMER.account_id
            and account_7.owner_id = ESTABLISHED_CUSTOMER.customer_id
         ) left join 
      work.EXCHANGE_RATES as EXCHANGE_RATES
         on
         (
            account_7.information_date = EXCHANGE_RATES.information_date
            and ESTABLISHED_CUSTOMER.currency_cd = EXCHANGE_RATES.currency_cd
            and EXCHANGE_RATES.base_currency_cd = 'EUR'
         )
   group by
      account_7.information_date,
      account_7.bank_id,
      account_7.owner_id
   order by
      account_7.bank_id,
      account_7.owner_id,
      account_7.account_id
   ;
quit;

