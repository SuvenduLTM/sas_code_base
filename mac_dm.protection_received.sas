         format = FINDFDD10.
         label = 'Valuation date',
      real_estate_location_fin.municipality_cd length = 6   
         label = 'Municipality code',
      real_estate_location_fin.zip_code length = 5   
         label = 'Zip Code',
      housing_object.post_office_number_id length = 10   
         label = 'Post office number (Postnummer)',
      housing_object.city_name length = 40   
         label = 'City name for the residential property (i vilken stad/ kommun bostaden är belägen)',
      housing_object.country_cd length = 2   
         label = 'Country code for the residential property (i vilket land bostaden är belägen)',
      protection_type_data.market_value_amt length = 8   
