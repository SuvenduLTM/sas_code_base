proc sql;
   create view work.original_protection_value as
   select
      original_protection_value_temp.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      original_protection_value_temp.collateral_number length = 8   
         format = 12.
         label = 'Collateral number (public)',
      original_protection_value_temp.market_value_amt length = 8   
         format = 15.2
         label = 'The estimated market value of the object',
      original_protection_value_temp.valuation_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Valuation date',
      original_protection_value_temp.collateral_loan_value_amt length = 8   
         format = 15.2
         label = 'Collateral value calculated from the market value',
      original_protection_value_temp.orig_collateral_loan_value_amt length = 8   
         format = 15.2
         label = 'Collateral value without secondary pledge included',
      original_protection_value_temp.currency_cd length = 3   
         label = 'The valuation currency',
      case when EXCHANGE_RATES_H.mid_rate is not missing then EXCHANGE_RATES_H.mid_rate 
       else (case when original_protection_value_temp.currency_cd = 'EUR' then 1 end) 
      end as mid_rate length = 8   
         format = 10.6
         label = 'Mean value of one base currency unit in currency (värdet på basvalutan i valutan)'
   from
      work.original_protection_value_temp as original_protection_value_temp left join 
      dw_dw.EXCHANGE_RATES_H as EXCHANGE_RATES_H
         on
         (
            original_protection_value_temp.valuation_date = EXCHANGE_RATES_H.information_date
            and (original_protection_value_temp.currency_cd = EXCHANGE_RATES_H.currency_cd
            and EXCHANGE_RATES_H.bank_id = 'A')
         )
   ;
quit;

