         label = 'Zip Code',
      code_count.count_municipality_cd length = 8   
         label = 'Municipality code count',
      code_count.count_zip_code length = 8   
         label = 'Zip Code count'
   from
      work.real_estate_location as real_estate_location left join 
      work.code_count as code_count
         on
         (
            real_estate_location.information_date = code_count.information_date
            and real_estate_location.bank_id = code_count.bank_id
            and real_estate_location.internal_collateral_id = code_count.internal_collateral_id
