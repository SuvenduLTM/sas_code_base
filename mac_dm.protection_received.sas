proc sql;
   create view work.original_protection_value_temp as
   select distinct
      collateral_first_occurence.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      collateral_first_occurence.collateral_number length = 8   
         format = 12.
         label = 'Collateral number (public)',
      sum(COLLATERAL_OBJECT_H.market_value_amt) as market_value_amt length = 8   
         format = 15.2
         label = 'The estimated market value of the object',
      min(COLLATERAL_OBJECT_H.valuation_date) as valuation_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Valuation date',
      COLLATERAL_H.collateral_loan_value_amt length = 8   
         format = 15.2
         label = 'Collateral value calculated from the market value',
      COLLATERAL_H.orig_collateral_loan_value_amt length = 8   
         format = 15.2
         label = 'Collateral value without secondary pledge included',
      COLLATERAL_H.currency_cd length = 3   
         label = 'The valuation currency'
   from
      work.collateral_first_occurence as collateral_first_occurence left join 
      dw_dw.COLLATERAL_OBJECT_LINK_H as COLLATERAL_OBJECT_LINK_H
         on
         (
            collateral_first_occurence.first_occurence_date = COLLATERAL_OBJECT_LINK_H.information_date
            and collateral_first_occurence.bank_id = COLLATERAL_OBJECT_LINK_H.bank_id
            and collateral_first_occurence.internal_collateral_id = COLLATERAL_OBJECT_LINK_H.internal_collateral_id
         ) left join 
      dw_dw.COLLATERAL_OBJECT_H as COLLATERAL_OBJECT_H
         on
         (
            COLLATERAL_OBJECT_LINK_H.information_date = COLLATERAL_OBJECT_H.information_date
            and COLLATERAL_OBJECT_LINK_H.bank_id = COLLATERAL_OBJECT_H.bank_id
            and COLLATERAL_OBJECT_LINK_H.internal_object_id = COLLATERAL_OBJECT_H.internal_object_id
         ) left join 
      dw_dw.COLLATERAL_H as COLLATERAL_H
         on
         (
            collateral_first_occurence.bank_id = COLLATERAL_H.bank_id
            and collateral_first_occurence.internal_collateral_id = COLLATERAL_H.internal_collateral_id
            and collateral_first_occurence.first_occurence_date = COLLATERAL_H.information_date
         )
   group by
      collateral_first_occurence.bank_id,
      collateral_first_occurence.collateral_number,
      COLLATERAL_H.collateral_loan_value_amt,
      COLLATERAL_H.orig_collateral_loan_value_amt,
      COLLATERAL_H.currency_cd
   ;
quit;

