      real_estate_location.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Information date of the record',
      real_estate_location.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      real_estate_location.internal_collateral_id length = 10   
         label = 'CBS internal collateral ID number (parent: COLLATERAL.internal_collateral_id)',
      case when code_count.count_municipality_cd = 1 then real_estate_location.municipality_cd else ' ' end as municipality_cd length = 6   
         label = 'Municipality code',
