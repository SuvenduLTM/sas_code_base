         label = 'The estimated market value of the object',
      collateral_distribution_amt.collateral_distribution_amt length = 8   
         format = 15.2
         label = 'Market value of the collateral'
   from
      work.collateral as collateral left join 
      work.instrument_protection as instrument_protection
         on
         (
            collateral.information_date = instrument_protection.information_date
            and collateral.bank_id = instrument_protection.bank_id
            and collateral.internal_collateral_id = instrument_protection.internal_collateral_id
         ) left join 
      work.exchange_rates as exchange_rates
         on
         (
            collateral.information_date = exchange_rates.information_date
            and collateral.currency_cd = exchange_rates.currency_cd
         ) left join 
      work.original_protection_value as original_protection_value
         on
