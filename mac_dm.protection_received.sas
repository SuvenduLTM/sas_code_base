%let etls_sql_pushDown = -1;
option DBIDIRECTEXEC;

proc datasets lib = work nolist nowarn memtype = (data view);
   delete protection_type_data;
quit;

proc sql;
   create view work.protection_type_data as
   select distinct
      collateral.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Information date of the record',
      collateral.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      collateral.internal_collateral_id length = 10   
         label = 'Collateral identification number',
      cat(collateral.bank_id,collateral.collateral_number) as protection_identifier length = 60   
         label = 'Protection Identifier',
      collateral_object.object_type_cd length = 4   
         label = 'Object type',
      sum(collateral_object.market_value_amt) as market_value_amt length = 8   
         format = 15.2
         label = 'The estimated market value of the object',
      collateral_object.collateral_loan_value_amt length = 8   
         format = 15.2
         label = 'Calculated loan value of collateral (belåningsvärde)',
      max(collateral_object.collateral_loan_value_amt) as max_collateral_loan_value_amt length = 8   
         format = 15.2,
      max(collateral_object.valuation_date) as max_valuation_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Valuation date'
   from
      work.collateral as collateral left join 
      work.collateral_object_link as collateral_object_link
         on
         (
            collateral.information_date = collateral_object_link.information_date
            and collateral.bank_id = collateral_object_link.bank_id
            and collateral.internal_collateral_id = collateral_object_link.internal_collateral_id
         ) left join 
      work.collateral_object as collateral_object
         on
         (
            collateral_object_link.information_date = collateral_object.information_date
            and collateral_object_link.bank_id = collateral_object.bank_id
            and collateral_object_link.internal_object_id = collateral_object.internal_object_id
         )
   group by
      collateral.information_date,
      collateral.bank_id,
      protection_identifier
   ;
quit;

