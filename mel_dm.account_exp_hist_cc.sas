      cc_inkasso_credit_sort.credit_limit_amt as collection_credit_limit_amt length = 8   
         format = 15.2
         label = 'Credit limit amount for collection',
      cc_inkasso_credit_sort.collection_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'First date for collection status',
      cc_inkasso_credit_sort.credit_loss_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'First date for credit loss status',
      ecl_cc_sort.stage_previous length = 3   
         format = 3.
         label = 'Forra stadie (1, 2 eller 3)',
      ecl_cc_sort.waiting_period_previous length = 8   
         format = 8.
         label = 'Förra karenstid (tiden som krediten måste stanna i det givna stadiet innan den får flytta till ett bättre stadie)',
      ecl_cc_sort.pd_initial_12m length = 8   
         format = 15.5
         label = 'Point in time 12-månaders PD-värde (sannolikheten för fallissemang inom det kommande året)',
      exchange_rates_eur.mid_rate as exchange_rate_eur length = 8   
         format = 10.6
         label = 'Exchange rate in eur (sek/eur)',
      exchange_rates_sek.mid_rate as exchange_rate_sek length = 8   
         format = 10.6
         label = 'Exchange rate in sek (eur/sek)'
   from
      work.cc_analysis_sort as cc_analysis_sort left join 
      work.cc_inkasso_credit_sort as cc_inkasso_credit_sort
         on
         (
            cc_analysis_sort.cc_account_id = cc_inkasso_credit_sort.cc_account_id
         ) left join 
      work.ecl_cc_sort as ecl_cc_sort
         on
         (
            cc_analysis_sort.information_date = ecl_cc_sort.information_date
            and cc_analysis_sort.cc_account_id = ecl_cc_sort.cc_account_id
         ) left join 
      work.exchange_rates_eur as exchange_rates_eur
         on
         (
            cc_analysis_sort.information_date = exchange_rates_eur.information_date
            and case 
               when cc_analysis_sort.source_company_id IN ( 'AAB', 'COB', 'TAP')
                  then 'EUR'
               when cc_analysis_sort.source_company_id = 'EBP'
                  then 'SEK'
            end
            = exchange_rates_eur.currency_cd
         ) left join 
      work.exchange_rates_sek as exchange_rates_sek
         on
         (
            cc_analysis_sort.information_date = exchange_rates_sek.information_date
            and case 
               when cc_analysis_sort.source_company_id = 'EBP'
                  then 'SEK'
               when cc_analysis_sort.source_company_id IN ( 'AAB', 'COB', 'TAP')
                  then 'EUR'
            end
            = exchange_rates_sek.currency_cd
         )
   ;
quit;

