            format = 15.2
            label = 'Accumulated impairment amount',
         "" as type_of_impairment length = 3
            label = 'Type of impairment',
         "" as impairment_assessment_method length = 3
            label = 'Impairment assessment method',
         "" as sources_of_encumbrance length = 3
            label = 'Sources of encumbrance',
         . as accum_chan_in_fairval_due_crisk length = 8
