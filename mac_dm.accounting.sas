         "" as performing_status_of_instrument length = 5
            label = 'Performing status of the instrument',
         . as date_of_perf_stat_of_instrument length = 8
            format = findfdd10.
            label = 'Date of the performing status of the instrument',
         . as off_balance_exp_provisions length = 8
            format = 15.2
            label = 'Provisions associated with off-balance sheet exposures',
         "" as status_of_forbearance_and_renego length = 3
            label = 'Status of forbearance and renegotiation',
         . as date_of_forbear_and_renego_stat length = 8
            format = findfdd10.
            label = 'Date of the forbearance and renegotiation status',
         . as cumulat_recoveries_since_default length = 8
            format = 15.2
            label = 'Cumulative recoveries since default',
         "" as prudential_portfolio length = 3
            label = 'Prudential portfolio',
         . as carrying_amount length = 8
            format = 15.2
            label = 'Carrying amount',
         bank_id,
         account_id,
         account_number_official,
         original_account_id,
         account_type_cd,
         customer_id_mod,
         name,
         opened_date,
         changed_date,
         default_start_date,
         overdraft_date,
         actual_due_date,
         expiry_date,
         currency_cd,
         mid_rate,
         booked_balance_amt,
         interest_amt,
         stage length = 8,
