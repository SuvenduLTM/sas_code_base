 * Description:     Select DistinctWHERE sum_of_exposures > 0 OR (          * 
 *                  booked_balance_amt_prev_month NOT IS MISSING AND        * 
 *                   booked_balance_amt_prev_month            < 0 )         * 
 *                                                                          * 
 * Source Tables:   shadow_OUTPUT0 - work.account_data    A5M8HTKH.BR00013J * 
 *                  shadow_OUTPUT0 - work.ecl_results     A5M8HTKH.BR00013K * 
 *                  shadow_OUTPUT0 -                      A5M8HTKH.BR00013L * 
 *                   work.credit_forbearance                                * 
 *                  shadow_OUTPUT0 - work.tms_detail      A5M8HTKH.BR00013M * 
 * Target Table:    Join - work.W1EVABCB                  A5M8HTKH.BR00013N * 
 *==========================================================================*/ 

%let transformID = %quote(A5M8HTKH.BU0001NZ);
%let trans_rc = 0;
%let etls_stepStartTime = %sysfunc(datetime(), datetime20.); 

%global etls_sql_pushDown;
%let etls_sql_pushDown = -1;
option DBIDIRECTEXEC;

proc datasets lib = work nolist nowarn memtype = (data view);
   delete W1EVABCB;
quit;

proc sql;
   create view work.W1EVABCB as
   select distinct
      account_data.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Information date of the record',
      account_data.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      account_data.account_id length = 20   
         label = 'Account Number',
      account_data.account_number_official length = 20   
         label = 'Account number official, In Finland this field is same as ACCNBR, in Sweden it contains the official Swedish account number',
      account_data.account_type_cd length = 3   
         label = 'CBS Account Type',
      account_data.customer_id_mod length = 60   
         label = 'Modified customer identifier',
      account_data.name length = 150   
         label = 'Customer Name (all customers)',
      account_data.original_account_id length = 14   
         label = 'Credit account id before it was on collection. 0 is allowed',
      account_data.default_start_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Default begin date',
      account_data.currency_cd length = 3   
         label = 'Account Currency code',
      account_data.mid_rate length = 8   
         format = 10.6
         label = 'Mean value of one base currency nit in currency',
      account_data.booked_balance_amt length = 8   
         format = 15.2
         label = 'Booked balance amount',
      account_data.overdraft_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Overdraft day 1.',
      account_data.interest_amt length = 8   
         format = 15.2
         label = 'Interest amount',
      account_data.actual_due_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Actual due date',
      account_data.expiry_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Limit expiry date',
      account_data.opened_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Account opened date',
      account_data.changed_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Account changed date',
      ecl_results.on_balance_ecl_euro_amt as on_balance_ecl length = 8   
         format = 15.2
         label = 'ECL-value in euro minumum level on balance monetary amount',
      ecl_results.off_balance_ecl_euro_amt as off_balance_ecl length = 8   
         format = 15.2
         label = 'ECL-value in euro minumum level off balance monetary amount',
      ecl_results.stage_cd as stage length = 3   
         format = 3.
         label = 'Stadie (1, 2 eller 3)',
      ecl_results.stage_change_dt length = 8   
         format = FINDFDD10.
         label = 'Stage change date',
      credit_forbearance.forbearance_status_cd length = 3   
         format = 3.
         label = 'Forbearance status',
      credit_forbearance.forbearance_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Forbearance date',
      credit_forbearance.action_status_cd length = 3   
         format = 3.
         label = 'Action status',
      credit_forbearance.performing_status_cd length = 3   
         format = 3.
         label = 'Performing status',
      tms_detail.covered_bonds_flag length = 3   
         format = 3.
         label = 'Used in covered bonds flag: 1=Yes, 0=No, .=unknown'
   from
      work.account_data as account_data left join 
      work.ecl_results as ecl_results
         on
         (
            account_data.information_date = ecl_results.information_date
            and account_data.bank_id = ecl_results.bank_id
            and account_data.account_id = ecl_results.account_id
         ) left join 
      work.credit_forbearance as credit_forbearance
         on
         (
            account_data.information_date = credit_forbearance.information_date
            and account_data.bank_id = credit_forbearance.bank_id
            and account_data.account_id = credit_forbearance.account_id
         ) left join 
      work.tms_detail as tms_detail
         on
         (
            account_data.information_date = tms_detail.information_date
            and account_data.bank_id = tms_detail.bank_id
            and account_data.account_id = tms_detail.account_id
         )
   where
      account_data.exposures_amt > 0
      or (account_data.booked_balance_amt_prev_month NOT IS MISSING 
      and account_data.booked_balance_amt_prev_month < 0)
   ;
quit;

