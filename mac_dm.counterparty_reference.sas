   delete customer_data;
quit;

proc sql;
   create view work.customer_data as
   select
      customer.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Information date of the record',
      customer.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      customer.customer_id length = 9   
         label = 'CBS Customer ID',
      cat(customer.bank_id, customer.customer_id) as counterparty_identifier length = 60   
         label = 'Counterparty Identifier',
      customer.ssn_id length = 20   
         label = 'Social security / organisation number',
      customer.customer_type length = 3   
         format = 3.
         label = '1=Private, 2=Coorp.cust.',
      customer.name length = 150   
         label = 'Customer Name (All customers)',
      customer.street_address length = 50   
         label = 'Street address',
      customer.post_office_number length = 10   
         label = 'Post office number',
      customer.country_cd length = 2   
         label = 'Address-country code',
      customer.post_office_name length = 40   
         label = 'Post office name',
      customer.legal_form_cd length = 2   
         label = 'Juridisk Form',
      customer.stat_sector_cd length = 6   
         label = 'Sektorkod. Obs : 6 siffror.',
      customer.stat_branch_cd length = 6   
         label = 'Näringsgren. Obs: 6 siffror i kundreg. Ngrenkp färre siffror (fyll ut med nollor)',
      customer.occupational_status_cd length = 1   
         label = 'Occupational status (1=worker, 2=lower officer, 3=higher officer…..) of private customer',
      customer.lei length = 20   
         label = ' Legal Entity Identifier',
      customer.lei_expiry_date length = 4   
         format = findfdd10.
         label = 'Date when the LEI expires',
      risk_customer_company.raiting_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Rating date',
      (case when customer.bank_id = 'B' then 'SEK'
       else 'EUR'
      end) as currency_cd length = 3   
         label = 'Currency code',
      risk_customer_company.turnover_amt length = 8   
         format = 15.2
         label = 'Turnover',
      risk_customer_company.total_assets_amt length = 8   
         format = 15.2
