quit;

proc sql;
   create view work.legalproceedings_orig as
   select
      customer_restrict_warn.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Information date of the record',
      customer_restrict_warn.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      customer_restrict_warn.customer_ssn_id length = 11   
         label = 'Customer´s SSN',
      customer_restrict_warn.customer_warning_cd length = 3   
         label = 'Restriction code (CODES.code_number_cd=''16'')',
      customer_restrict_warn.valid_from_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'First date when restriction/warning is valid',
      customer_restrict_warn.customer_2_ssn_id length = 11   
         label = 'Other customers´ SSN If warning connected to another customer',
      customer_restrict_warn.warning_text length = 90   
         label = 'Free text',
      code_converter.code_value_char length = 14   
         label = 'Code value character',
      code_converter.internal_value_prio length = 8   
         format = 8.
         label = 'Calculation priority order',
      count(*) as dup_seq length = 8
   from
      work.customer_restrict_warn as customer_restrict_warn left join 
      work.code_converter as code_converter
         on
         (
            customer_restrict_warn.information_date = code_converter.information_date
            and customer_restrict_warn.bank_id = code_converter.bank_id
            and customer_restrict_warn.customer_warning_cd = code_converter.internal_value_char
         )
   where
      code_converter.code_type = 'CL_LGL_PRCDNG_STTS_AC'
      and customer_restrict_warn.valid_from_date <= customer_restrict_warn.information_date
      and (customer_restrict_warn.valid_to_date >= customer_restrict_warn.information_date
      or customer_restrict_warn.valid_to_date IS MISSING )
   group by
      customer_restrict_warn.customer_ssn_id
   order by
      customer_restrict_warn.information_date,
      customer_restrict_warn.bank_id,
      customer_restrict_warn.customer_ssn_id,
      code_converter.internal_value_prio
   ;
quit;

