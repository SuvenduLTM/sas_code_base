 *                  shadow_OUTPUT0 - work.account_owners  A5ZNM6KG.BV0004KS * 
 *                  shadow_OUTPUT0 - work.customer        A5ZNM6KG.BV0004KT * 
 *                  shadow_OUTPUT0 - work.par_filters     A5ZNM6KG.BV0004KU * 
 * Target Table:    Join - work.W28WSMLU                  A5ZNM6KG.BV0004KW * 
 *==========================================================================*/ 

%let transformID = %quote(A5ZNM6KG.BS0005GZ);
%let trans_rc = 0;
