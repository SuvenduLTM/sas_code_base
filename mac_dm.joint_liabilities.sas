option DBIDIRECTEXEC;

proc datasets lib = work nolist nowarn memtype = (data view);
   delete W28WSMLU;
quit;

proc sql;
   create view work.W28WSMLU as
   select
      account_data.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Information date of the record',
      account_data.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      account_data.account_id length = 20   
         label = 'Account Number',
      account_data.account_number_official length = 20   
         label = 'Account number official, In Finland this field is same as ACCNBR, in Sweden it contains the official Swedish account number',
      account_data.original_account_id length = 14   
         label = 'Credit account id before it was on collection. 0 is allowed',
      account_data.currency_cd length = 3   
         label = 'Account Currency code',
      account_data.mid_rate length = 8   
         format = 10.6
         label = 'Mean value of one base currency nit in currency',
      account_data.booked_balance_amt length = 8   
         format = 15.2
         label = 'Booked balance amount',
      cat(account_owners.bank_id, account_owners.owner_id) as counterparty_identifier length = 20,
      customer.name length = 150   
         label = 'Customer Name (All customers)'
   from
      work.account_data as account_data left join 
      work.account_owners as account_owners
         on
         (
            account_data.information_date = account_owners.information_date
            and account_data.bank_id = account_owners.bank_id
            and account_data.account_id = account_owners.account_id
         ) left join 
      work.customer as customer
         on
         (
            account_owners.information_date = customer.information_date
            and account_owners.bank_id = customer.bank_id
            and account_owners.owner_id = customer.customer_id
         ) left join 
      work.par_filters as par_filters_sector_cd
         on
         (
            customer.information_date = par_filters_sector_cd.information_date
            and customer.bank_id = par_filters_sector_cd.bank_id
            and customer.stat_sector_cd = par_filters_sector_cd.code_value_char
            and par_filters_sector_cd.target_column = 'stat_sector_cd'
         ) left join 
      work.par_filters as par_filters_customer_type
         on
         (
            customer.information_date = par_filters_customer_type.information_date
            and customer.bank_id = par_filters_customer_type.bank_id
            and customer.customer_type = par_filters_customer_type.code_value_num
            and par_filters_customer_type.target_column = 'customer_type'
         )
   where
      par_filters_customer_type.code_value_num IS MISSING 
      and par_filters_sector_cd.code_value_char IS MISSING 
      and account_data.shared <> '0'
      and (account_data.exposures_amt > 0
      or account_data.booked_balance_amt_prev_qtr < 0)
   ;
quit;

