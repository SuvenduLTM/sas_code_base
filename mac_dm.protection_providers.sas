 *                  Extract - work.counterparty_debtor    A5ZNM6KG.BV0004LH * 
 * Target Table:    Join - work.W2OXUZD3                  A5ZNM6KG.BV0004LG * 
 *==========================================================================*/ 

%let transformID = %quote(A5ZNM6KG.BS0005HM);
%let trans_rc = 0;
%let etls_stepStartTime = %sysfunc(datetime(), datetime20.); 

%global etls_sql_pushDown;
%let etls_sql_pushDown = -1;
option DBIDIRECTEXEC;

proc datasets lib = work nolist nowarn memtype = (data view);
   delete W2OXUZD3;
quit;

proc sql;
   create view work.W2OXUZD3 as
   select distinct
      collateral.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Information date of the record',
      collateral.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      cat(collateral.bank_id, collateral.collateral_number) as protection_identifier length = 60   
         format = 12.
         label = 'Protection identifier',
      cat(collateral_giver.bank_id, collateral_giver.internal_giver_id) as protection_provider_identifier length = 60   
         label = 'Protection provider identifier',
      customer.name length = 150   
         label = 'Customer Name (All customers)',
      customer.stat_sector_cd length = 6   
         label = 'Sektorkod. Obs : 6 siffror.'
   from
      work.collateral as collateral left join 
      work.collateral_giver as collateral_giver
         on
         (
            collateral.information_date = collateral_giver.information_date
            and collateral.bank_id = collateral_giver.bank_id
            and collateral.internal_collateral_id = collateral_giver.internal_collateral_id
         ) left join 
      work.customer as customer
         on
         (
            collateral_giver.information_date = customer.information_date
            and collateral_giver.bank_id = customer.bank_id
            and collateral_giver.internal_giver_id = customer.customer_id
         ) left join 
      work.account_collateral_link as account_collateral_link
         on
         (
            collateral.information_date = account_collateral_link.information_date
            and collateral.bank_id = account_collateral_link.bank_id
            and collateral.internal_collateral_id = account_collateral_link.internal_collateral_id
         ) left join 
      work.counterparty_debtor as counterparty_debtor
         on
         (
            account_collateral_link.information_date = counterparty_debtor.information_date
            and account_collateral_link.bank_id = counterparty_debtor.bank_id
            and account_collateral_link.account_id = counterparty_debtor.account_id
         )
   where
      counterparty_debtor.account_id NOT IS MISSING 
      and (collateral.collateral_loan_value_amt > 1
