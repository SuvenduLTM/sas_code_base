         label = 'LGD-value by isin or by ticker',
      case when W9I4U1A1.bloomberg_lgd_pct is missing then 0.6 else W9I4U1A1.bloomberg_lgd_pct end as lgd_pct length = 8   
         format = 8.4
         label = 'Loss given value. 0,6 for unsecured bonds and 0,05 pct for covered exposures',
