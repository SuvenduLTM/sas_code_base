proc sql;
   create table work.WA1AZ3NS as
   select
      account_daily.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Date of the underlying data',
      customer.name as counterparty_name length = 150   
         label = 'Name of the counterparty',
      account.account_id as instrument_name length = 40   
         label = 'Name of bond or in case of bankaccount, the accountnumber',
      customer.name as parent_name length = 150   
         label = 'Name of ultimate counterparty. Same as counterparty in many cases.',
      account.owner_ssn_id as counterparty_id_parent length = 20   
         label = 'Internal counterparty identifier in DW, i.e. the SSN-numer or internally constructed',
      "" as bb_ticker_id length = 40   
         label = 'Identifiers according to Bloomberg.',
      "" as instrument_isin_id length = 20   
         label = 'The indentifier according to ISIN for Bonds in the treasury position table',
      account.account_number_official as bdb_account_id length = 40   
         label = 'Deal id for bonds and account number for bank accounts',
      case when account.owner_ssn_id in ('0202248-1','950120-9906') then "sovereigns_and_centralbanks" else "institutions" end as type_code length = 40   
         label = 'Main exposure type accounting to Basel exposure class',
      case when account.owner_ssn_id in ('0202248-1','950120-9906') then "sovereigns_and_centralbanks" else "institutions" end as type length = 40   
         label = 'Main exposure type and type of instrument (bond and bank account)',
      . as open_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Open date only used for bonds',
      "11283" as book_account_cd length = 10   
         label = 'Main ledger account number',
      "" as book_account_name length = 90   
         label = 'Text description of main ledgerD',
      &active_date.+1 as maturity_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Date when a bond matures. For bankaccounts always information date+1 day',
      1 as maturity_in_days length = 4   
         format = 8.
         label = 'Day count to maturity day',
      "" as overnight_deposit length = 3   
         label = 'Y if maturity day is +1 and deals is a deposit',
      . as interest_rate length = 8   
         format = 10.6
         label = 'Interest date percent for bonds. Empty for bank accounts',
      . as amort_frequency length = 3   
         format = 3.
         label = 'Empty',
      . as next_payment_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Empty',
      . as date_next_payment length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Empty',
      abs(account_daily.booked_balance_amt) as book_value length = 8   
         format = 15.2
         label = 'Value according to balance sheet',
      abs(account_daily.booked_balance_amt) as notional_amt length = 8   
         format = 15.2
         label = 'Notional amount in eur.',
      0 as accrued_interest length = 8   
         format = 15.2
         label = 'Accured interest for bonds. Empty for all others.',
      . as bloomberg_pd_pct length = 8   
         format = 10.7
         label = 'One year pd value for bonds or counterparty linked from data entry table',
      . as lgd_pct length = 8   
         format = 8.4
         label = 'Loss given default value. Fixed 0.6 for unsecured bonds and 0.05 pct for covered exposures',
      "" as rate_type length = 20   
         label = 'Fixed of floating rate of bonds',
      "N" as covered length = 3   
         label = 'Y if the instrument is covered',
      "" as bullet length = 5   
         label = 'Empty',
      abs(account_daily.booked_balance_amt) as ead_eur length = 8   
         format = 15.2
         label = 'Exposure value',
      "" as rtg_sp length = 10   
         label = 'Rating point.External rating is converted to a number used in calculations.',
      "" as rtg_mdy length = 10   
         label = 'Rating point.External rating is converted to a number used in calculations.',
      "" as rtg_fitch length = 10   
         label = 'Rating point.External rating is converted to a number used in calculations.',
      . as pd_initial_lifetime length = 8   
         format = 15.5
         label = 'Empty',
      case when WAHSYQ5H.account_id  ='' then 1 else 0 end as new_exposure_flg length = 3   
         format = 3.
         label = 'Value 1, if issuer cd not present prviousious periods else 0',
      "corebank" as source length = 20   
         label = 'Source of data: treasury position, corebank or manual'
   from
      work.account_daily as account_daily left join 
      work.account as account
         on
         (
            account_daily.information_date = account.information_date
            and account_daily.bank_id = "A"
            and account_daily.account_id = account.account_id
         ) left join 
      work.customer as customer
         on
         (
            account.information_date = customer.information_date
            and account.bank_id = customer.bank_id
            and account.owner_id = customer.customer_id
         ) left join 
      work.WAHSYQ5H as WAHSYQ5H
         on
         (
            account.bank_id = WAHSYQ5H.bank_id
            and account.account_id = WAHSYQ5H.account_id
         )
   where
      account.account_type_cd IN ( '263', '260','270','272','280' '082')
      and account.bank_id = "A"
      and strip(account.owner_ssn_id) NOT IN ('0145019-3', '950185-830T')
   ;
quit;

