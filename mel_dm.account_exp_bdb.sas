      W9I4U1A1.bullet length = 5   
         label = 'Bullet (Fixed value of ''N'')',
      W9I4U1A1.ead_eur length = 8   
         format = 15.2
         label = 'Exposure value',
      W9I4U1A1.rtg_sp length = 10   
         label = 'Rating point. External rating is converted to a number and used in calculations',
      W9I4U1A1.rtg_mdy length = 10   
         label = 'Rating point. External rating is converted to a number and used in calculations',
      W9I4U1A1.rtg_fitch length = 10   
         label = 'Rating point.External rating is converted to a number used in calculations.',
      case when ecl_bdb_previous.pd_initial_12m_previous is not missing then ecl_bdb_previous.pd_initial_12m_previous
      else W9I4U1A1.pd_initial_12m end as pd_initial_12m length = 8   
         format = 15.5
         label = 'Point in time 12-months PD value',
      W9I4U1A1.pd_initial_lifetime length = 8   
         format = 15.5
         label = 'Empty',
      W9I4U1A1.unmanaged_days_cnt length = 3   
         format = 3.
         label = 'Unmanaged days count',
      W9I4U1A1.new_exposure_flg length = 3   
         format = 3.
         label = 'If issuer cd not present in previous periods,1,0',
      W9I4U1A1.source length = 20   
         label = 'Source of data: treasury position, corebank or manual',
      ecl_bdb_previous.stage_previous length = 3   
         format = 3.
         label = 'Stadie (1, 2 eller 3)',
      ecl_bdb_previous.waiting_period_previous length = 8   
         format = 8.
         label = 'Karenstid (tiden som krediten måste stanna i det givna stadiet innan den får flytta till ett bättre stadie)',
      %sysfunc(round(%sysfunc(datetime()),1)) as loaded_dt length = 8   
         format = DATETIME20.
         label = 'Load timestamp (date & time)'
   from
      work.W9I4U1A1 as W9I4U1A1 left join 
      work.ecl_bdb_previous as ecl_bdb_previous
         on
         (
            W9I4U1A1.information_date = ecl_bdb_previous.information_date
            and W9I4U1A1.bdb_account_id = ecl_bdb_previous.bdb_account_id
         )
   ;
