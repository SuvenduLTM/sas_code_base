      W9ZDQEB3.amort_frequency length = 3   
         format = 3.
         label = 'Empty',
      W9ZDQEB3.next_payment_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Empty',
      W9ZDQEB3.date_next_payment length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Empty',
      W9ZDQEB3.book_value length = 8   
