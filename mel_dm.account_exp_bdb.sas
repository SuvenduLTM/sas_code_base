option DBIDIRECTEXEC;

/*---- Map the columns  ----*/ 
proc datasets lib = work nolist nowarn memtype = (data view);
   delete treasury_bonds;
quit;

data _null_;
   put "NOTE: The following column(s) do not have a column mapping, so the"
        " value(s) will be set to missing: bb_ticker_id, overnight_deposit,"
        " amort_frequency, next_payment_date,    date_next_payment,"
        " bloomberg_pd_pct, lgd_pct, bullet, rtg_sp, rtg_mdy,    rtg_fitch,"
        " pd_initial_lifetime, unmanaged_days_cnt, new_exposure_flg";
run;

%put %str(NOTE: Mapping columns ...);
proc sql;
   create table work.treasury_bonds as
      select
         information_date   
            label = 'Date of the underlying data',
         issuer_cd as counterparty_name   
            label = 'Name of the counterparty',
         instrument_name   
            label = 'Name of bond or in case of bankaccount, the accountnumber',
         issuer_cd as parent_name   
            label = 'Name of ultimate counterparty. Same as counterparty in many cases.',
         counterparty_ssn10_id as counterparty_id_parent   
            label = 'Internal counterparty identifier in DW, i.e. the SSN-numer or internally constructed',
         "" as bb_ticker_id length = 40
            label = 'Identifiers according to Bloomberg.',
         instrument_isin_id   
            label = 'The indentifier according to ISIN for Bonds in the treasury position table',
         (strip(put(deal_number_id ,6.))) as bdb_account_id length = 40
            label = 'Deal id for bonds and account number for bank accounts',
         (case  when instrument_exposure_class_cd='1' then "soverings_and_central_banks"
             when instrument_exposure_class_cd='2' then "local_governments"
             when instrument_exposure_class_cd='3' then "spublic_sector_entities"
             when instrument_exposure_class_cd='4' then "multilateral_developments_banks"
             when instrument_exposure_class_cd='5' then "international_organisations"
             when instrument_exposure_class_cd='6' then "institutions"
             when instrument_exposure_class_cd='7' then "corporates"
             when instrument_exposure_class_cd='12' then "covered_bonds"
            else "others"
            end) as type_code length = 40
            label = 'Main exposure type accounting to Basel exposure class',
         (case  when  instrument_exposure_class_cd in  ('1', '2','3','4','5') then "bonds, soverings"
              when instrument_exposure_class_cd='6' then "bonds, institutions"
            when  instrument_exposure_class_cd='12' then "covered_bonds"
            end) as type length = 40
            label = 'Main exposure type and type of instrument (bond and bank account)',
         start_sett_date as open_date   
            label = 'Open date only used for bonds',
         book_account_cd   
            label = 'Main ledger account number',
         instrument_group_cd as book_account_name length = 90   
            label = 'Text description of main ledgerD',
         maturity_date   
            label = 'Date when a bond matures. For bankaccounts always information date+1 day',
         days_to_maturity_cnt as maturity_in_days   
            label = 'Day count to maturity day',
         "" as overnight_deposit length = 3
            label = 'Y if maturity day is +1 and deals is a deposit',
         irr_pct as interest_rate   
            label = 'Interest date percent for bonds. Empty for bank accounts',
         . as amort_frequency length = 3
            format = 3.
            label = 'Empty',
         . as next_payment_date length = 4
            format = FINDFDD10.
            informat = DDMMYY10.
            label = 'Empty',
         . as date_next_payment length = 4
            format = FINDFDD10.
            informat = DDMMYY10.
            label = 'Empty',
         book_value_eur_amt as book_value   
            label = 'Value according to balance sheet',
         face_value_balance_eur_amt as notional_amt   
            label = 'Notional amount in eur.',
         (spot_factor *coupon_accrual_amt) as accrued_interest length = 8
            format = 15.2
            label = 'Accured interest for bonds. Empty for all others.',
         . as bloomberg_pd_pct length = 8
            format = 10.7
            label = 'One year pd value for bonds or counterparty linked from data entry table',
         . as lgd_pct length = 8
            format = 8.4
            label = 'Loss given default value. Fixed 0.6 for unsecured bonds and 0.05 pct for covered exposures',
         (case when reference_rate_cd="" then "Floating"
            else "Fixed"
            end) as rate_type length = 20
            label = 'Fixed of floating rate of bonds',
         (case when instrument_exposure_class_cd='12' then "N"
            else "Y"
            end) as covered length = 3
            label = 'Y if the instrument is covered',
         "" as bullet length = 5
            label = 'Empty',
         (case when book_account_cd in ('15830','15840') then (spot_factor*book_value_clean_amt)  +(spot_factor*coupon_accrual_amt)
            else  market_value_amt *spot_factor
            end) as ead_eur length = 8
            format = 15.2
            label = 'Exposure value',
         "" as rtg_sp length = 10
            label = 'Rating point.External rating is converted to a number used in calculations.',
         "" as rtg_mdy length = 10
            label = 'Rating point.External rating is converted to a number used in calculations.',
         "" as rtg_fitch length = 10
            label = 'Rating point.External rating is converted to a number used in calculations.',
         . as pd_initial_lifetime length = 8
            format = 15.5
            label = 'Empty',
         . as unmanaged_days_cnt length = 3
            format = 3.
            label = 'Empty',
         . as new_exposure_flg length = 3
            format = 3.
            label = 'Value 1, if issuer cd not present prviousious periods else 0',
         ("treasury_bonds") as source length = 20
            label = 'Source of data: treasury position, corebank or manual'
   from &SYSLAST
      where transaction_type_cd='SE' and pay_or_receive_cd='R' and trim(issuer_cd) ne "BANK OF ALAND"
   ;
quit;

%let SYSLAST = work.treasury_bonds;

%global etls_sql_pushDown;
%let etls_sql_pushDown = &sys_sql_ip_all;

