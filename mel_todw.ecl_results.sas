option DBIDIRECTEXEC;

proc datasets lib = work nolist nowarn memtype = (data view);
   delete W750X799;
quit;

proc sql;
   create view work.W750X799 as
   select
      &active_date. as information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Information date',
      ECL_resu_union.account_id length = 20   
         label = 'Key to connect LLG assets with BASEL tables, and CC assets with Credit card accounts (BDB deal id converted to character as part of the PK)',
      ECL_resu_union.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden, .=N/A or missing',
      ECL_resu_union.ecl_result_cd length = 3   
         label = 'Internal key with values ´LLG´, ´CC´ or ´BDB´ (part of PK)',
      ECL_resu_union.ecl_result_type length = 20   
         label = 'Type: ´loan_portfolio´, ´treasury_position´ or ´credit_cards´',
      ECL_resu_union.bdb_type length = 20   
         label = 'BDB exposure type based on instrument_exposure_class (´bonds,sovereigns´ for 1,2,3,4,5´, ´bonds,institutions´ for 6, ´covered bonds´ for 12)',
      ECL_resu_union.deal_number_id length = 6   
         format = 10.
         label = 'Key to connect with Treasury tables (numeric)',
      ECL_resu_union.source_company_id length = 3   
         label = 'Company ID from where data originates: TAP, COB, or AAB',
      ECL_resu_union.parent_name length = 100   
         label = 'Issuer (text code)',
      ECL_resu_union.bb_ticker_id length = 25   
         label = 'The ticker for the counterpartry according to Bloomberg',
      ECL_resu_union.account_number_official length = 20   
         label = 'Account Number, official (In Finland same as account_id, in Sweden the official Swedish account number). LLG only.',
      ECL_resu_union.final_ecl_euro_amt length = 8   
         format = 15.2
         label = 'Expected Credit Losses (ECL) final amount (ecl_amt for CC and BDB, ecl_euro_min_lvl_amt for LLG)',
      ECL_resu_union.on_balance_ecl_euro_amt length = 8   
         format = 15.2
         label = 'On-balance ECL amount',
      ECL_resu_union.off_balance_ecl_euro_amt length = 8   
         format = 15.2
         label = 'Off-balance ECL amount',
      ECL_RESULTS_prev.ecl_amt as final_ecl_prev_month_eur_amt length = 8   
         format = 15.2
         label = 'ECL amount in the previous month calculation',
      ECL_resu_union.final_ecl_sek_amt length = 8   
         format = 15.2
         label = 'Final ECL with the minimum level amount (SEK)',
      ECL_resu_union.off_balance_ecl_sek_amt length = 8   
         format = 15.2
         label = 'Final off-balance ECL with the minimum level amount (SEK)',
      ECL_resu_union.on_balance_ecl_sek_amt length = 8   
         format = 15.2
         label = 'Final on-balance ECL with the minimum level amount (SEK)',
      ECL_resu_union.ead_future_1_euro_amt length = 8   
         format = 15.2
         label = 'Exposure at Default (EAD) modeled (1 year) EUR',
      ECL_resu_union.ead_future_1_sek_amt length = 8   
         format = 15.2
         label = 'Exposure at Default (EAD) modeled (1 year) SEK',
      ECL_resu_union.lgd_future_1_pct length = 8   
         format = 15.5
         label = 'Estimated Loss Given Default (LGD) for the time period 1 (1=100%)',
      ECL_resu_union.pd_actual_12m_pct length = 8   
         format = 15.5
         label = 'Probability of Default (PD) in 12 months from now (sannolikheten för fallissemang inom det kommande året)',
      ECL_resu_union.pd_actual_future_1_pct length = 8   
         format = 15.5
         label = 'PD 1st year after adjustment by an expert group based on current data (PD år 1 efter justering gjord av expertgruppen på basen av aktuell data)',
      ECL_resu_union.pd_actual_lifetime_pct length = 8   
         format = 15.5
         label = 'Lifetime PD for remaining time based on current data  (Lifetime PD för återstående tid beräknat med aktuell data)',
      ECL_resu_union.pd_initial_lifetime_pct length = 8   
         format = 15.5
         label = 'Lifetime PD for remaining time based on initial data  (Lifetime PD för återstående tid beräknat med initial data)',
      ECL_resu_union.waiting_period length = 8   
         format = 8.
         label = 'Waiting period between stages (Förra karenstid - tiden som krediten måste stanna i det givna stadiet innan den får flytta till ett bättre stadie)',
      ECL_resu_union.stage_cd length = 3   
         format = 3.
         label = 'Stage: 1, 2, or 3 (Stadie)',
      ECL_RESULTS_prev.stage_cd as stage_previous_month_cd length = 3   
         format = 3.
         label = 'Stage in previous calculation',
      ECL_RESULTS_prev.stage_change_dt_previous_month length = 8   
         format = FINDFDD10.
         label = 'Stage change date previous month',
      ECL_resu_union.ecl_override_flg length = 3   
         format = 3.
         label = 'ECL override flag: 0=no, 1=yes',
      %sysfunc(round(%sysfunc(datetime()),1)) as loaded_dt length = 8   
         format = DATETIME20.
         label = 'Load timestamp (date & time)'
   from
      work.ECL_resu_union as ECL_resu_union left join 
      work.ECL_RESULTS_prev as ECL_RESULTS_prev
         on
         (
            ECL_resu_union.account_id = ECL_RESULTS_prev.account_id
            and ECL_resu_union.bank_id = ECL_RESULTS_prev.bank_id
            and ECL_resu_union.ecl_result_cd = ECL_RESULTS_prev.ecl_result_cd
         )
   ;
quit;

