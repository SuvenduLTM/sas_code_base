   -------------------------------------------------------------- */
%macro etls_loader;

   %let etls_tableOptions = ;
   
   /* Determine if the target table exists  */ 
   %let etls_tableExist = %eval(%sysfunc(exist(mco_ctrl.PAR_CONVERT_VALUE_S, DATA)) or 
         %sysfunc(exist(mco_ctrl.PAR_CONVERT_VALUE_S, VIEW))); 
   
   %let etls_hasUpdateIndex=0; 
   
   /*---- Create a new table  ----*/ 
   %if (&etls_tableExist eq 0) %then 
   %do;  /* if table does not exist  */ 
   
      %put %str(NOTE: Creating table ...);
      
      data mco_ctrl.PAR_CONVERT_VALUE_S;
         attrib information_date length = 4
            format = FINDFDD10.
            label = 'Information date'; 
         attrib par_convert_id length = 8
            label = 'Surrogate key'; 
         attrib source_libname length = $8
            label = 'Source_data'; 
         attrib source_data length = $32
            label = 'Source data'; 
         attrib source_column length = $32
            label = 'Source column'; 
         attrib source_bank_id length = $3
            label = 'Source Bank ID'; 
         attrib source_value length = $2
            label = 'Source value to be converted'; 
         attrib target_libname length = $8
            label = 'Target libname'; 
         attrib target_data length = $32
            label = 'Target data'; 
         attrib target_column length = $32
            label = 'Target column'; 
         attrib target_bank_id length = $3
            label = 'Target Bank ID'; 
         attrib target_value length = $2
            label = 'The value after conversion'; 
         attrib loaded_dt length = 8
            format = DATETIME20.
            label = 'Load timestamp (date & time)'; 
         call missing(of _all_);
         stop;
      run;
      
      %rcSet(&syserr); 
      
      /*---- Create the indexes for a table  ----*/ 
      %put %str(NOTE: Creating indexes ...);
      proc datasets lib = mco_ctrl nolist; 
         modify PAR_CONVERT_VALUE_S; 
            index create primary_index = (information_date par_convert_id)
               / unique nomiss;
      quit; 
      
      %rcSet(&syserr); 
      
   %end;  /* if table does not exist  */ 
   
   /*---- Begin Modify Step  ----*/ 
   /* Allow user to specify IORC values to trigger step to stop. Initialize if  */ 
   /*  not assigned.                                                            */ 
   %if NOT %symexist(etls_StopOnIORC) %then %let etls_StopOnIORC=;
    
   data mco_ctrl.PAR_CONVERT_VALUE_S; 
      length etls_msg $200; 
      drop etls_msg; 
      modify mco_ctrl.PAR_CONVERT_VALUE_S 
             &etls_lastTable
             updatemode = nomissingcheck 
      ; 
      
      by par_convert_id;
      
      /* if the record does not exist in the master, then add it  */ 
      if %sysrc(_DSENMR) eq _iorc_ then 
         output; 
      /* if the record exists in the master, then replace it  */ 
      else if %sysrc(_SOK) eq _iorc_ then 
         replace; 
      %if &etls_StopOnIORC ne %then
      %do;
         if _iorc_ in (&etls_StopOnIORC) then
         do;
            etls_msg = iorcmsg();
            put etls_msg; 
            %rcSetDS(5)
            stop;
         end;
      %end;
      _iorc_ = 0; 
      _error_ = 0; 
      
   run; 
   
   %rcSet(&syserr); 
   
   %let etls_StopOnIORC=; /* reset to blank */ 
   
%mend etls_loader;
%etls_loader;



/**  Step end Table Loader **/

%let etls_endTime = %sysfunc(datetime(),datetime.);

/*---- Start of Post-Process Code  ----*/ 

%postprocess_std;
/*---- End of Post-Process Code  ----*/ 

%rcSet(&syserr); 
%rcSet(&sqlrc); 

