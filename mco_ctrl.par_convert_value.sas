%let _libr=%sysfunc(scan(&syslast.,1,'.')) ;
%let _tabl=%sysfunc(scan(&syslast.,2,'.')) ;
%let current_rows_in_target=0;
filename _sqlobs temp;

data _null_ ;
exists=exist("&syslast","DATA");
ext_len_target=2 ; *Snip as many chars as needed to get the target table name. ;
* Check the target libname in the following line., if not the same as source library ;
target_libr="&_libr." ;
target_tabl=substr(target_libr!!".&_tabl",1,length(target_libr!!".&_tabl")-ext_len_target) ; 
call symput('target_tabl',target_tabl) ;
call symput('_s_obs','0') ;
call symput('_main_obs','MAX') ;
file _sqlobs ;
put '* Get number of rows in main table ;';
file log ;
if not exists then do ;
  ext_len_source=2 ; *Snip as many chars as needed to get the new source table name. ;
  tablename=substr("dw_stg.&_tabl",1,length("dw_stg.&_tabl")-ext_len_source) ; 
  exists=exist(tablename,"DATA");
  if exists then do;
    call symput('syslast',tablename) ;
    call symput('_s_obs','MAX') ;
    call symput('_main_obs','0') ;
  end;
  else do ;
    put "ERROR: Table &syslast does not exist and the alternative source " tablename " does not exist either. ";
    abort abend;
  end ;
end ;
else do;
  file _sqlobs ;
  put 'proc sql noprint ; select count(*) from &target_tabl. where information_date=&active_date ; quit ;';
  put '%let current_rows_in_target=&sqlobs;';
  file log ;
end ;
run ;
%include _sqlobs ;

%put NOTE: syslast=&syslast, target_tabl=&target_tabl. current_rows_in_target=&current_rows_in_target. ; 

data _null_ ;
if &current_rows_in_target>0 then do ;
  tablename=substr("&syslast",1,length("&syslast")-2)!!'_H'; 
  exists=exist(tablename,"VIEW");
  if exists then do;
    call symput('syslast',tablename) ;
  end;
  else do ;
    put "ERROR: View &syslast does not exist. ";
    abort abend;
  end ;
end ;
run ;
