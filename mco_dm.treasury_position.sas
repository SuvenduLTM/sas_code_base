         label = 'Risk exposure: If(D1Instrument_Risk_Weight=´10 %´, Book Value*0.1,If(D1Instrument_Risk_Weight=´20 %´, Book Value*0.2,If(D1Instrument_Risk_Weight=´50 %´, Book Value*0.5,0)))',
      TREASURY_POSITION.risk_exp_eur_amt length = 8   
         format = 15.2
         label = 'Risk exposure EUR: (Risk_Exp_Amount*Spot_Factor)',
      TREASURY_POSITION.risk_exp_mod_eur_amt length = 8   
         format = 15.2
         label = 'Risk exposure modified EUR: If(RW_Mod=´10 %´, Book_Value_EUR*0.1,If(RW_Mod=´20 %´, Book_Value_EUR*0.2,If(RW_Mod=´50 %´, Book_Value_EUR*0.5,0)))',
      TREASURY_POSITION.ead_eur length = 8   
         format = 15.2
         label = 'Exposure at Default metric / from the calculated column (function)',
      TREASURY_POSITION.reference_rate_cd length = 20   
         label = 'Reference rate  (text code): eg. Euribor Live',
      TREASURY_POSITION.rate_name length = 80   
         label = 'Rate name',
      TREASURY_POSITION.rate_pct length = 8   
         format = 10.6
         label = 'Rate: D1Rate Cross Currency Swap,Discount Security,FRA,Interest Rate Swap,Money Market: eg. 0.183',
      TREASURY_POSITION.margin_pct length = 8   
         format = 10.6
         label = 'D1Margin Cross Currency Swap,Interest Rate Swap,Money Market: eg. 0.97',
      TREASURY_POSITION.irr_pct length = 8   
         format = 10.6
         label = 'Calculated Internal Rate of Return/dynamic, from point of time column: eg. 0.222',
      TREASURY_POSITION.interest_rate_pct length = 8   
         format = 10.6
         label = 'Interest rate %: D1Rate +D1Margin',
      TREASURY_POSITION.valuation_time length = 4   
         format = TIME6.
         label = 'Valuation time',
      TREASURY_POSITION.hqla_lcr_level_cd length = 6   
         label = 'High Quality Liqudity Assets code for LCR calculation: 100, 107, 9100, 2A15 or empty',
      case when DET_COREP_ECL.ecl_amount =. then 0 
      else DET_COREP_ECL.ecl_amount  
      end as ecl_amount length = 8   
         format = 15.2
         label = 'ECL amount',
      DET_COREP_ECL.stage_cd length = 3   
         format = 6.
         label = 'Stage, eg. 1, 2, 3',
      TREASURY_POSITION.source_system_cd length = 3   
         label = 'Data source system',
      TREASURY_POSITION.extracted_dt length = 8   
         format = DATETIME20.
         label = 'Extract timestamp (date & time)',
      TREASURY_POSITION.loaded_dt length = 8   
         format = DATETIME20.
         label = 'Load timestamp (date & time)'
   from
      work.TREASURY_POSITION as TREASURY_POSITION left join 
      work.DET_COREP_ECL as DET_COREP_ECL
         on
         (
            TREASURY_POSITION.information_date = DET_COREP_ECL.information_date
            and TREASURY_POSITION.deal_id = DET_COREP_ECL.deal_id
            and (substr(TREASURY_POSITION.book_account_cd,1,1) = "1"
            and DET_COREP_ECL.deal_id > 0)
         )
   ;
quit;

