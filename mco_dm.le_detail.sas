proc sql;
   create view work.le_derivatives as
   select
      'Derivatives' as product_name length = 40   
         format = $40.,
      shadow_inst_grouping.group_lei_id as code length = 50   
         format = $50.
         label = 'SSN of the Entity/Group/Mother: e.g. 0144123-4 or 230264-1234',
      shadow_inst_grouping.client_lei_id as code_client length = 50   
         format = $50.
         label = 'Social security / organisation number',
      . as debt_instruments length = 8   
         format = 15.2
         label = 'Book value EUR: (Book_Value*Spot_Factor)',
      shadow_basel_irb_der.exposure_at_default_amount as derivatives length = 8   
         format = 15.2,
      -shadow_basel_irb_der.collateral_received_amount as _Funded_credit_prot_not_subst length = 8   
         format = 15.2,
      substr(shadow_basel_irb_der.counterparty_name,1,90) as individual_name length = 90   
         label = 'counterparty/issuer name (key)',
      shadow_inst_grouping.information_date length = 4   
         format = findfdd10.
         label = 'Query position date',
      case when shadow_basel_irb_der.sm_exposure_class in ('06','12') then shadow_basel_irb_der.maturity_date 
      else . 
      end as maturity_date length = 4   
         format = findfdd10.
         label = 'Maturity date',
      case when shadow_basel_irb_der.sm_exposure_class in ('06','12') then shadow_basel_irb_der.exposure_at_default_amount 
      else 0  
      end as exposure_at_default_amount length = 8   
         format = 15.2
   from
      work.shadow_basel_irb_der as shadow_basel_irb_der left join 
      work.shadow_inst_grouping as shadow_inst_grouping
         on
         (
            shadow_basel_irb_der.counterparty_name = shadow_inst_grouping.client_name
         )
   where
      not (shadow_basel_irb_der.exposure_at_default_amount = 0
      and shadow_basel_irb_der.collateral_received_amount = 0)
   ;
quit;

