   create view work.W4M0U8B0 as
      select
         information_date,
         deal_id,
         transaction_type_cd,
         book_value_eur_amt,
         issuer_cd,
         instrument_exposure_class_cd,
         (case when transaction_type_cd in ('SE','MM') and instrument_exposure_class_cd in ('6','12') then maturity_date
