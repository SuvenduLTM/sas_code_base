proc datasets lib = work nolist nowarn memtype = (data view);
   delete LE_nostro_accounts;
quit;

proc sql;
   create view work.LE_nostro_accounts as
   select
      'Nostro_accounts' as product_name length = 40,
      extract_customer.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Query position date',
      extract_customer.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      extract_customer.customer_id length = 9   
         label = 'CBS Customer ID',
      extract_customer.ssn_id length = 20   
         label = 'Social security / organisation number',
      extract_customer.name as individual_name length = 90   
         label = 'Customer Name (All customers)',
      extract_customer.stat_sector_cd length = 6   
         label = 'Sektorkod. Obs : 6 siffror.',
      shadow_inst_grouping.client_lei_id as code_client length = 50,
      shadow_inst_grouping.group_lei_id as code length = 50,
      extract_account.owner_ssn_id length = 20   
         label = 'Social Sec.number / Org.number. Account owner',
      ABS(extract_account_daily.booked_balance_amt/shadow_currency.exchange_rate) as debt_instruments length = 8   
         format = 15.2,
      (extract_account_daily.booked_balance_amt/shadow_currency.exchange_rate)
      *((substr(extract_customer.stat_sector_cd,1,3) in('121','321'))) as _amounts_exempted length = 8   
         format = 15.2
   from
      work.extract_customer as extract_customer left join 
      work.shadow_inst_grouping as shadow_inst_grouping
         on
         (
            extract_customer.name = shadow_inst_grouping.client_name
         ), 
      work.extract_account as extract_account left join 
      work.shadow_currency as shadow_currency
         on
         (
            extract_account.currency_cd = shadow_currency.currency_cd
         ), 
      work.extract_account_daily as extract_account_daily
   where
      extract_account.account_id = extract_account_daily.account_id
      and extract_customer.ssn_id = extract_account.owner_ssn_id
   ;
quit;

