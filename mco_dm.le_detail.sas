%global etls_sql_pushDown;
%let etls_sql_pushDown = -1;
option DBIDIRECTEXEC;

proc datasets lib = work nolist nowarn memtype = (data view);
   delete LE_treasury_bonds;
quit;

proc sql;
   create view work.LE_treasury_bonds as
   select
      W4M0U8B0.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Query position date',
      'Bonds' as product_name length = 40   
         format = $40.,
      shadow_inst_grouping.group_lei_id as code length = 50   
         format = $50.
         label = 'SSN of the Entity/Group/Mother: e.g. 0144123-4 or 230264-1234',
      shadow_inst_grouping.client_lei_id as code_client length = 50   
         format = $50.
         label = 'Social security / organisation number',
      max(W4M0U8B0.book_value_eur_amt,0) as debt_instruments length = 8   
         format = 15.2
         label = 'Book value EUR: (Book_Value*Spot_Factor)',
      -W4M0U8B0.book_value_eur_amt
      *(W4M0U8B0.instrument_exposure_class_cd in('1','2','3','4','5','9'))     
      -(0.9*W4M0U8B0.book_value_eur_amt)*(W4M0U8B0.instrument_exposure_class_cd='12') as _amounts_exempted length = 8   
         format = 15.2
         label = '(-) Amounts exempted',
      W4M0U8B0.issuer_cd as individual_name length = 90,
      W4M0U8B0.maturity_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Maturity date',
      W4M0U8B0.book_value_eur_amt_orig length = 8   
         format = 15.2
         label = 'Book value EUR: (Book_Value*Spot_Factor)'
   from
      work.W4M0U8B0 as W4M0U8B0, 
      work.shadow_inst_grouping as shadow_inst_grouping
   where
      W4M0U8B0.issuer_cd = shadow_inst_grouping.client_name
      and not (calculated debt_instruments = 0
      and calculated _amounts_exempted = 0)
   ;
quit;

%global etls_sql_pushDown;
%let etls_sql_pushDown = &sys_sql_ip_all;

%rcSet(&sqlrc); 



