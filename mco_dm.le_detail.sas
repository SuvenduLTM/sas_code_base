         (sum(debt_instruments, equity_instruments, derivatives, loan_commitments, 
              financial_guarantees, other_commitments)) as original_exposure_amount length = 8
            format = 15.2
            label = 'Original exposure value',
         (sum(debt_instruments, equity_instruments, derivatives, loan_commitments, 
              financial_guarantees, other_commitments, _value_adjust_and_provis)) as Exposure_value length = 8
            format = 15.2
            label = 'Book value EUR: (Book_Value*Spot_Factor)',
         (sum(debt_instruments, equity_instruments, derivatives, loan_commitments, 
              financial_guarantees, other_commitments, _value_adjust_and_provis, 
              _financial_guarantees, crm__financial_guarantees, _Funded_credit_prot_not_subst, 
              _real_estate, _Amounts_exempted)) as Exposure_after_exempt_n_crm length = 8
            format = 15.2
            label = 'Book value EUR: (Book_Value*Spot_Factor)',
         (%sysfunc(round(%sysfunc(datetime()),1))) as loaded_dt length = 8
            format = DATETIME20.
            label = 'Load timestamp (date & time)',
         individual_name   
            label = 'counterparty/issuer name (key in some products)',
         information_date,
         sector_code,
         maturity_date,
         bucket_value_amount
   from &SYSLAST
      where code_client ne ' ' and not (calculated original_exposure_amount=0 and calculated Exposure_value=0 and calculated Exposure_after_exempt_n_crm=0)
   ;
quit;

