         (b_exposure_amount*(b_balance_sheet=0)*(1-(counterparty_risk_type in("G","F") ))) as loan_commitments length = 8
            format = 15.2
            label = 'Off balance sheet S-method exposure amount',
         (b_exposure_amount*(counterparty_risk_type in("G","F"))) as financial_guarantees length = 8
            format = 15.2,
         (b_exposure_amount*(counterparty_risk_type="XX")) as other_commitments length = 8
            format = 15.2,
         impairment_losses_amount as _value_adjust_and_provis   
            label = 'impairment_losses_amount (<0)',
         (-b_exposure_amount*(b_exposure_class in('01','02','03','04','05','06'))) as crm__financial_guarantees length = 8
            format = 15.2,
         (case 
             when (b_exposure_class="IRB" and b_row_number=1) then -crm_amount
             when b_exposure_class="CRM" then -b_exposure_amount
             else 0
            end) as _Funded_credit_prot_not_subst length = 8
            format = 15.2,
         (case 
             when (b_exposure_class="IRB" and b_row_number=1) then -housing_collateral_amount*0.5 
             when b_exposure_class="09B" then -b_exposure_amount*0.5
             else 0
            end) as _real_estate length = 8
            format = 15.2,
         "" as individual_name length = 90
            label = 'counterparty/issuer name (key)',
         information_date   
            label = 'Query position date'
   from &SYSLAST
      where customer_ssn_id ne ' '
   ;
quit;

