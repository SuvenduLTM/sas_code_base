proc sql;
   create view work.W2N8Y3MD as
   /* Returns all unique rows from the two query results.  */ 
   select
      debtor.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Information date of the record',
      debtor.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      debtor.account_id length = 20   
         label = 'Account Number',
      debtor.counterparty_identifier length = 60   
         label = 'Counterparty Identifier',
      debtor.account_number_official length = 20   
         label = 'Account number official, In Finland this field is same as ACCNBR, in Sweden it contains the official Swedish account number',
      debtor.original_account_id length = 14   
         label = 'Credit account id before it was on collection. 0 is allowed',
      debtor.counterparty_role length = 8   
         label = 'Counterparty role'
   from
      work.debtor
   union all  
   select
      creditor.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Information date of the record',
      creditor.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      creditor.account_id length = 20   
         label = 'Account Number',
      creditor.counterparty_identifier length = 60   
         label = 'Counterparty Identifier',
      creditor.account_number_official length = 20   
         label = 'Account number official, In Finland this field is same as ACCNBR, in Sweden it contains the official Swedish account number',
      creditor.original_account_id length = 14   
         label = 'Credit account id before it was on collection. 0 is allowed',
      creditor.counterparty_role length = 8   
         label = 'Counterparty role'
   from
      work.creditor
   /* Returns all unique rows from the two query results.  */ 
   union all  
   select
      servicer.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Information date of the record',
      servicer.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      servicer.account_id length = 20   
         label = 'Account Number',
      servicer.counterparty_identifier length = 60   
         label = 'Counterparty Identifier',
      servicer.account_number_official length = 20   
         label = 'Account number official, In Finland this field is same as ACCNBR, in Sweden it contains the official Swedish account number',
      servicer.original_account_id length = 14   
         label = 'Credit account id before it was on collection. 0 is allowed',
      servicer.counterparty_role length = 8   
         label = 'Counterparty role'
   from
      work.servicer
   ;
quit;

