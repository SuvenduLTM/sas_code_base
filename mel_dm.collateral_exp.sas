         format = DATETIME20.
         label = 'Extract timestamp (date & time)',
      %sysfunc(round(%sysfunc(datetime()),1)) as loaded_dt length = 8   
         format = DATETIME20.
   from
      work.COLLATERAL as COLLATERAL left join 
      work.MORTGAGE as MORTGAGE
         on
         (
            COLLATERAL.information_date = MORTGAGE.information_date
            and COLLATERAL.bank_id = MORTGAGE.bank_id
            and COLLATERAL.internal_collateral_id = MORTGAGE.Internal_collateral_id
         ) left join 
      work.SECONDARY_PLEDGES as SECONDARY_PLEDGES
         on
         (
            COLLATERAL.information_date = SECONDARY_PLEDGES.information_date
            and COLLATERAL.bank_id = SECONDARY_PLEDGES.bank_id
            and COLLATERAL.internal_collateral_id = SECONDARY_PLEDGES.internal_collateral_id
         )
   where
      SECONDARY_PLEDGES.information_date = SECONDARY_PLEDGES.information_date
      and SECONDARY_PLEDGES.bank_id = SECONDARY_PLEDGES.bank_id
      and SECONDARY_PLEDGES.internal_secondary_pledge_id = SECONDARY_PLEDGES.internal_secondary_pledge_id
   ;
quit;

