proc sql;
   create table work.SECONDARY_PLEDGES as
   select
      COLL_SECONDARY_PLEDGE_LINK.information_date length = 4   
         format = FINDFDD10.
         label = 'Information date of the record',
      COLL_SECONDARY_PLEDGE_LINK.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      COLL_SECONDARY_PLEDGE_LINK.internal_collateral_id length = 10   
         label = 'CBS internal collateral ID number (parent: COLLATERAL.internal_collateral_id)',
      COLL_SECONDARY_PLEDGE_LINK.internal_secondary_pledge_id length = 10   
         label = 'CBS internal secondary pledge ID number (parent: SECONDARY_PLEDGE.internal_secondary_pledge_id)',
      SECONDARY_PLEDGE.direction_cd length = 20   
         label = 'Direction code if the pledge has been GIVEN or TAKEN',
      SECONDARY_PLEDGE.currency_cd length = 3   
         label = 'Currency of the secondary pledge',
      SECONDARY_PLEDGE.counterparty_name length = 120   
         label = 'Name of the company given/received the pledge',
      SECONDARY_PLEDGE.signing_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'The date when the secondary pledge was signed',
      SECONDARY_PLEDGE.priority_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Priority date (Företrädesdatum)',
      SECONDARY_PLEDGE.given_1_amt length = 8   
         format = 15.2
         label = 'Amount 1 to which the pledge is limited',
      SECONDARY_PLEDGE.received_1_amt length = 8   
         format = 15.2
         label = 'Amount 1 from which the pledge is received',
      SECONDARY_PLEDGE.given_2_amt length = 8   
         format = 15.2
         label = 'Amount 2 to which the pledge is limited',
      SECONDARY_PLEDGE.received_2_amt length = 8   
         format = 15.2
         label = 'Amount 2 from which the pledge is received',
      SECONDARY_PLEDGE.given_3_amt length = 8   
         format = 15.2
         label = 'Amount 3 to which the pledge is limited',
      SECONDARY_PLEDGE.received_3_amt length = 8   
         format = 15.2
         label = 'Amount 3 from which the pledge is received',
      SECONDARY_PLEDGE.given_4_amt length = 8   
         format = 15.2
         label = 'Amount 4 to which the pledge is limited',
      SECONDARY_PLEDGE.received_4_amt length = 8   
         format = 15.2
         label = 'Amount 4 from which the pledge is received',
      SECONDARY_PLEDGE.given_5_amt length = 8   
         format = 15.2
         label = 'Amount 5 to which the pledge is limited',
      SECONDARY_PLEDGE.received_5_amt length = 8   
         format = 15.2
         label = 'Amount 5 from which the pledge is received'
   from
      work.COLL_SECONDARY_PLEDGE_LINK as COLL_SECONDARY_PLEDGE_LINK, 
      work.SECONDARY_PLEDGE as SECONDARY_PLEDGE
   where
      COLL_SECONDARY_PLEDGE_LINK.information_date = SECONDARY_PLEDGE.information_date
      and COLL_SECONDARY_PLEDGE_LINK.bank_id = SECONDARY_PLEDGE.bank_id
      and COLL_SECONDARY_PLEDGE_LINK.internal_secondary_pledge_id = SECONDARY_PLEDGE.internal_secondary_pledge_id
   ;
quit;

