         format = 15.2
         label = 'Nominal value of the mortgage deed',
      MORTGAGE.total_priority_amt length = 8   
         format = 15.2
         label = 'Total nominal amount of all mortgage deeds with a better preference than the current mortgage deed plus the the nominal amount of the current deed',
      SECONDARY_PLEDGES.currency_cd as currency_cd_sec_pledge length = 3   
         label = 'Currency of the secondary pledge',
      SECONDARY_PLEDGES.given_1_amt length = 8   
         format = 15.2
         label = 'Amount 1 to which the pledge is limited',
      SECONDARY_PLEDGES.received_1_amt length = 8   
         format = 15.2
         label = 'Amount 1 from which the pledge is received',
      SECONDARY_PLEDGES.given_2_amt length = 8   
         format = 15.2
         label = 'Amount 2 to which the pledge is limited',
      SECONDARY_PLEDGES.received_2_amt length = 8   
         format = 15.2
         label = 'Amount 2 from which the pledge is received',
      SECONDARY_PLEDGES.given_3_amt length = 8   
         format = 15.2
         label = 'Amount 3 to which the pledge is limited',
      SECONDARY_PLEDGES.received_3_amt length = 8   
         format = 15.2
         label = 'Amount 3 from which the pledge is received',
      SECONDARY_PLEDGES.given_4_amt length = 8   
         format = 15.2
         label = 'Amount 4 to which the pledge is limited',
      SECONDARY_PLEDGES.received_4_amt length = 8   
         format = 15.2
         label = 'Amount 4 from which the pledge is received',
      SECONDARY_PLEDGES.given_5_amt length = 8   
         format = 15.2
         label = 'Amount 5 to which the pledge is limited',
      SECONDARY_PLEDGES.received_5_amt length = 8   
         format = 15.2
         label = 'Amount 5 from which the pledge is received',
