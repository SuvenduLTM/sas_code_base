data _null_;
 if not exist("meh_todw.ECL_RESULTS") then do ;
  put "NOTE: meh_todw.ECL_RESULTS does not exist. OK for the 1st run. ";  
  call execute("proc datasets lib = work nolist nowarn memtype = (data view);delete ECL_RESULTS_prev;quit;");
  call execute("data ECL_RESULTS_prev; length information_date 3 account_id $20 bank_id $1 ecl_result_cd $3 ecl_amt 8 stage_cd 3 stage_previous_month_cd 3; run ;");
 end ;
