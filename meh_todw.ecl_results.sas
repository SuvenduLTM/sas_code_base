      ECL_resu_union.lgd_future_1 length = 8,
      ECL_resu_union.ead_future_1 length = 8,
      ECL_resu_union.pd_actual_future_1 length = 8,
      ECL_resu_union.calculated_end_date length = 8
   from
      work.ECL_resu_union as ECL_resu_union left join 
      work.ECL_RESULTS_prev as ECL_RESULTS_prev
         on
