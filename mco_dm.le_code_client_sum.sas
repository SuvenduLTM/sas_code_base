         (sum(equity_instruments)) as equity_instruments length = 8
            format = 15.2
            label = 'Equity instruments',
         (sum(derivatives)) as derivatives length = 8
            format = 15.2
            label = 'Derivatives',
         (sum(loan_commitments)) as loan_commitments length = 8
            format = 15.2
            label = 'Loan commitments',
         (sum(financial_guarantees)) as financial_guarantees length = 8
            format = 15.2
            label = 'Financial guarantees',
         (sum(other_commitments)) as other_commitments length = 8
            format = 15.2
            label = 'Other commitments',
         (sum(_value_adjust_and_provis)) as _value_adjust_and_provis length = 8
            format = 15.2
            label = '(-) Value adjustments and provisions',
         (sum(_financial_guarantees)) as _financial_guarantees length = 8
            format = 15.2
            label = '(-) Financial Guarantees',
         (sum(crm__financial_guarantees)) as crm__financial_guarantees length = 8
            format = 15.2
            label = 'CRM (-) Financial Guarantees',
         (sum(_funded_credit_prot_not_subst)) as _Funded_credit_prot_not_subst length = 8
            format = 15.2
            label = '(-) Funded credit protection other than substitution effect',
         (sum(_real_estate)) as _real_estate length = 8
            format = 15.2
            label = '(-) Real estate',
         (sum(_amounts_exempted)) as _amounts_exempted length = 8
            format = 15.2
            label = '(-) Amounts exempted',
         (sum(original_exposure_amount)) as original_exposure_amount length = 8
            format = 15.2
            label = 'Original exposure value',
         (sum(exposure_value)) as exposure_value length = 8
            format = 15.2
            label = 'Exposure value',
         (sum(exposure_after_exempt_n_crm)) as Exposure_after_exempt_n_crm length = 8
            format = 15.2
            label = 'Exposure value after exemptions and crm',
         information_date
   from &SYSLAST
      where information_date=&active_date
   group by
      code,
      code_client
   order by
      code,
      code_client
   ;
quit;

