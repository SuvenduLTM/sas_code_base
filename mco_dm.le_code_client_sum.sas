proc datasets lib = work nolist nowarn memtype = (data view);
   delete W621AL3P;
quit;

proc sql;
   create view work.W621AL3P as
   select distinct
      sum_by_code_client.code length = 50   
         format = $50.
         label = 'SSN of the Entity/Group/Mother: e.g. 0144123-4 or 230264-1234',
      case shadow_det_le_customer.group_individual 
        when 'eba_ZZ:x2' then 'eba_ZZ:x2' 
        when ' ' then 'eba_ZZ:x1' 
        else ' ' 
      end as group_individual length = 16,
      sum_by_code_client.code_client length = 50   
         format = $50.
         label = 'Social security / organisation number',
      sum_by_code_client.defaulted length = 8   
         format = 15.2
         label = 'Defaulted',
      sum_by_code_client.debt_instruments length = 8   
         format = 15.2
         label = 'Debt instruments',
      sum_by_code_client.equity_instruments length = 8   
         format = 15.2
         label = 'Equity instruments',
      sum_by_code_client.derivatives length = 8   
         format = 15.2
         label = 'Derivatives',
      sum_by_code_client.loan_commitments length = 8   
         format = 15.2
         label = 'Loan commitments',
      sum_by_code_client.financial_guarantees length = 8   
         format = 15.2
         label = 'Financial guarantees',
      sum_by_code_client.other_commitments length = 8   
         format = 15.2
         label = 'Other commitments',
      sum_by_code_client._value_adjust_and_provis length = 8   
         format = 15.2
         label = '(-) Value adjustments and provisions',
      sum_by_code_client._financial_guarantees length = 8   
         format = 15.2
         label = '(-) Financial Guarantees',
      sum_by_code_client.crm__financial_guarantees length = 8   
         format = 15.2
         label = 'CRM (-) Financial Guarantees',
      sum_by_code_client._Funded_credit_prot_not_subst length = 8   
         format = 15.2
         label = '(-) Funded credit protection other than substitution effect',
      sum_by_code_client._real_estate length = 8   
         format = 15.2
         label = '(-) Real estate',
      sum_by_code_client._amounts_exempted length = 8   
         format = 15.2
         label = '(-) Amounts exempted',
      sum_by_code_client.original_exposure_amount length = 8   
         format = 15.2
         label = 'Original exposure value',
      sum_by_code_client.exposure_value length = 8   
         format = 15.2
         label = 'Exposure value',
      sum_by_code_client.Exposure_after_exempt_n_crm length = 8   
         format = 15.2
         label = 'Exposure value after exemptions and crm',
      case 
      when extract_eligible_capital.eligible_capital_205 ne . 
      then sum_by_code_client.exposure_value /extract_eligible_capital.eligible_capital_205
      else .
      end as eligible_capital_1_pct length = 8   
         format = 10.7,
      case 
      when extract_eligible_capital.eligible_capital_205 ne . then
      sum_by_code_client.Exposure_after_exempt_n_crm  /extract_eligible_capital.eligible_capital_205
      else .
      end as eligible_capital_2_pct length = 8   
         format = 10.7,
      %sysfunc(round(%sysfunc(datetime()),1)) as loaded_dt length = 8   
         format = DATETIME20.
         label = 'Load timestamp (date & time)',
      sum_by_code_client.information_date length = 4   
         format = findfdd10.
         label = 'Information date',
      sum_by_code_client.note_txt length = 40   
         label = 'Adjustment made',
      case 
      when ext_eligible_capital_201.eligible_capital_201 ne . 
      then sum_by_code_client.exposure_value /ext_eligible_capital_201.eligible_capital_201 
      else .
      end as eligible_capital_1_pct_201 length = 8   
         format = 10.7,
      case 
      when ext_eligible_capital_201.eligible_capital_201  ne . then
      sum_by_code_client.Exposure_after_exempt_n_crm/ext_eligible_capital_201.eligible_capital_201 
      else .
      end as eligible_capital_2_pct_201 length = 8   
         format = 10.7
   from
      work.sum_by_code_client as sum_by_code_client left join 
      work.extract_eligible_capital as extract_eligible_capital
         on
         (
            extract_eligible_capital.information_date = sum_by_code_client.information_date
         ) left join 
      work.shadow_det_le_customer as shadow_det_le_customer
         on
         (
            sum_by_code_client.code_client = shadow_det_le_customer.code
         ) left join 
      work.ext_eligible_capital_201 as ext_eligible_capital_201
         on
         (
            sum_by_code_client.information_date = ext_eligible_capital_201.information_date
         )
   ;
quit;

