proc sql; 
  create table transposed_migr as
  select a.* 
        ,coalesce(b.unmgd_days, a.unmanaged_days_orig)    as unmanaged_days_cnt
        ,coalesce(b.new_credit_flg, a.new_credit_flg_orig) as new_credit_flg

  from transposed_5(rename=( 
                            unmanaged_days_cnt  = unmanaged_days_orig
                            new_credit_flg      = new_credit_flg_orig
                    )) as a left join 
        MIGRATED_LOANS as b 
  on a.information_date=b.information_date and a.account_number_official=b.official_accnbr;
quit;

/*always us another initial date and uc_pd if it does not exist */
proc sql; 
  create table transposed_6 as
  select a.* 
        ,coalesce(b.initial_date_fix, a.initial_date_orig) as initial_date
        ,coalesce(a.uc_pd_class_value_orig, b.pdvalue)    as uc_pd_class_value

  from transposed_migr (rename=(uc_pd_class_value   = uc_pd_class_value_orig
                            initial_date        = initial_date_orig
                    )) as a left join 
        MIGRATED_LOANS as b 
  on a.account_number_official=b.official_accnbr;
quit;


