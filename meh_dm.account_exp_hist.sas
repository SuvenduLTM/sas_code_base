if intck('month',information_date, &active_date.)+1<14;
run;

data account_exp_lt; set account_exp_ht; if information_date=&active_date.; run;

proc sort data=account_exp_lt(keep=bank_id account_id owner1_ssn_id owner2_ssn_id ) 
       out=unmanaged_days_01 nodupkey; 
by bank_id account_id owner1_ssn_id ; run;


