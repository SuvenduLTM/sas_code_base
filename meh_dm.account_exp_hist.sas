proc sort nodupkey data=account_exp_h_acc out=ready_for_transX dupout=duppi; by bank_id account_id  numero; run;
/* How many Months does thje data contain */
/* put this number into a macro variable */

proc sql noprint;
select max (numero) into :max_num
from ready_for_transX;
quit;

%put 'Maximum Months found = ' &max_num;

/* A Macro routine to check the number of months */
%macro num_check;
/* Only run if extra months needed */
	%if %sysevalf(&max_num+1 < 14) %then %do;
/* Get all the account_id's */ 
		proc sql;
			create table miss_acc
	 		as select distinct bank_id, account_id
	 		from ready_for_transX;
	 	quit;
/* System needs 13 months, add the missing */
/* Values set to missing */
		data add_rows(drop=i a);
	 		set miss_acc;
			length exposure_balance_avg_amt unmanaged_days_max_cnt past_due_days_max_cnt 8 overdraft_days_max_cnt 3;
         a=coalesce(&max_num,0);
	 	do i=a+1 to 13;
			exposure_balance_avg_amt=.;
			unmanaged_days_max_cnt=.;
			overdraft_days_max_cnt=.;
         past_due_days_max_cnt=.;
			numero = i;
			output;
	  	end;
	  run;
	 /* Add the rows back to the original table */

		data ready_for_trans;
			set ready_for_transX
	  			add_rows;
	  	run;
	/* Sort the table so it is the same before the routine */
		proc sort data=ready_for_trans; 
			by bank_id account_id numero; 
		run;
	%end;
   %else %do;
		* Fix för att få igenom programmet då inget defaultdata skapas för månad 12... Variabeln Past_due_days_max_cnt saknas helt i och med det *;
		proc sql;
		  create table ready_for_trans as
		  select information_date, 
		         bank_id, 
		         account_id, 
		         exposure_balance_avg_amt, 
		         unmanaged_days_max_cnt,
		         overdraft_days_max_cnt, 
				 . as past_due_days_max_cnt,
		         numero
		  from ready_for_transX;
		quit;
   %end;	
%mend;%num_check;



