/* ACCOUNT BALANCE */
%_eg_conditional_dropds(WORK.QUERY_FOR_DWI_ACCOUNT_ATTR_DAILY);

PROC SQL;
   CREATE TABLE WORK.QUERY_FOR_DWI_ACCOUNT_ATTR_DAILY AS 
   SELECT DISTINCT t1.information_date, 
          t1.bank_id, 
          t1.account_id, 
          t1.account_number_official, 
          t1.account_type_aab, 
          /* deposit_balance */
            (t1.deposit_balance/t1.total_owner_count) AS deposit_balance, 
          /* lending_balance */
            ((t1.lending_balance+t1.overdraft)/t1.total_owner_count) AS lending_balance, 
          t1.current_limit_amt, 
          t1.overdraft, 
          t1.total_owner_count
      FROM &DW_OUTLIB..DWI_ACCOUNT_ATTR_DAILY t1
      WHERE t1.information_date = &date_active AND t1.account_type_aab NOT IS MISSING;
QUIT;


