/* --- Start of code for "Query Builder (22)". --- */
%_eg_conditional_dropds(WORK.QUERY_FOR_DWI_CUSTODY_0000);

PROC SQL;
   CREATE TABLE WORK.QUERY_FOR_DWI_CUSTODY_0000 AS 
   SELECT t1.information_date, 
          t1.bank_id, 
          t1.customer_id, 
          /* own_funds */
            (SUM(t1.own_funds)) FORMAT=COMMA12. AS own_funds, 
          /* FV_DISK */
            (SUM(t1.FV_DISK)) AS FV_DISK, 
          /* FV_KONS */
            (SUM(t1.FV_KONS)) AS FV_KONS, 
          /* FV_OVRIGT */
            (SUM(t1.FV_OVRIGT)) AS FV_OVRIGT, 
          /* market_value */
            (SUM(t1.market_value)) AS market_value, 
          /* SUM_of_custody_market_value */
            (SUM(t1.custody_market_value)) FORMAT=BEST12. AS SUM_of_custody_market_value
      FROM WORK.QUERY_FOR_DWI_CUSTODY t1
      GROUP BY t1.information_date,
               t1.bank_id,
               t1.customer_id;
QUIT;
/* --- End of code for "Query Builder (22)". --- */

/* --- Start of code for "Query Builder (2)". --- */
