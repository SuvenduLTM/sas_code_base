/* CARD BALANCE */
%_eg_conditional_dropds(WORK.QUERY_FOR_DWI_CREDIT_CARD_BALANC);

PROC SQL;
   CREATE TABLE WORK.QUERY_FOR_DWI_CREDIT_CARD_BALANC AS 
   SELECT t1.information_date, 
          t1.bank_id, 
          t1.AH_SSN, 
          /* BALANCE */
            (SUM(t1.BALANCE)) FORMAT=19.2 AS BALANCE
      FROM &DW_PAYLIB..CARD_BALANCE t1
      WHERE t1.information_date = &date_active AND t1.COMPANY_SHORT_NAME IN 
           (
           'AAB',
           'EBP'
           )
      GROUP BY t1.information_date,
               t1.bank_id,
               t1.AH_SSN;
QUIT;

/* CUSTODY */

%_eg_conditional_dropds(WORK.QUERY_FOR_DWI_CUSTODY);

PROC SQL;
   CREATE TABLE WORK.QUERY_FOR_DWI_CUSTODY AS 
   SELECT t1.information_date, 
          t1.bank_id, 
          t1.portfolio_id, 
          t1.courtage_month, 
          t1.market_value, 
          t1.custody_market_value, 
          t1.mandate_type, 
          t1.own_funds, 
          t1.custody_fee_y, 
          t1.ssn_id, 
          t1.customer_id, 
          t1.management_fee_pct, 
          t1.loaded_dt, 
          /* FV_DISK */
            (CASE WHEN t1.mandate_type="Diskretionär" THEN t1.market_value
            ELSE 0
            END) AS FV_DISK, 
          /* FV_KONS */
            (CASE WHEN t1.mandate_type="Konsultativ" THEN t1.market_value
            ELSE 0
            END) AS FV_KONS, 
          /* FV_OVRIGT */
            (
            Case when t1.mandate_type="ÖVRIGT" OR t1.mandate_type="Övrigt" THEN t1.market_value
            ELSE 0
            END) AS FV_OVRIGT
      FROM &DW_OUTLIB..DWI_CUSTODY t1
      WHERE t1.information_date = &onefactor_date_active;
QUIT;

