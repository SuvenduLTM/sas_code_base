QUIT;
/* --- End of code for "Query Builder (2)". --- */

/* --- Start of code for "calc per account". --- */
%_eg_conditional_dropds(WORK.QUERY_FOR_CUSTOMER2);

PROC SQL;
   CREATE TABLE WORK.QUERY_FOR_CUSTOMER2 AS 
   SELECT t1.information_date, 
          t1.bank_id, 
          t1.customer_id, 
          t1.ssn_id, 
          t1.account_id, 
          t1.customer_type, 
          t1.name, 
          t1.result_office_id, 
          t1.advisor1_id, 
          t4.deposit_balance FORMAT=NUMX12. AS deposit_balance, 
          /* INL_MEAN */
            (t7.avg_deposit_book_amt/t4.total_owner_count) FORMAT=NUMX12. AS INL_MEAN, 
          /* lending_balance */
            (-t4.lending_balance) FORMAT=NUMX12. AS lending_balance, 
          /* UTL_MEAN */
            (-t7.avg_lending_book_amt/t4.total_owner_count) FORMAT=NUMX12. AS UTL_MEAN, 
          /* UTL_CREDITCARD */
            (-t8.BALANCE) FORMAT=NUMX12. AS UTL_CREDITCARD, 
          t9.own_funds, 
          t9.FV_DISK, 
          t9.FV_KONS, 
          t9.FV_OVRIGT, 
          t9.SUM_of_custody_market_value AS custody_market_value, 
          /* aum_funds */
            (case when t9.FV_DISK=0 and t9.FV_KONS=0 then t9.own_funds
            else 0 end) AS aum_funds, 
          /* aum */
            (t9.FV_DISK+t9.FV_KONS+t9.own_funds) AS aum, 
          /* aum_sum */
            (case when t9.FV_KONS is not missing then t9.FV_KONS else 0 end +
            case when t9.FV_DISK is not missing then t9.FV_DISK else 0 end +
            case when t9.FV_KONS=0 AND t9.FV_DISK=0 and t9.own_funds is not missing then t9.own_funds else 0 end) AS 
            aum_sum, 
          /* capital_requirements */
            (t2.capital_requirements/t4.total_owner_count) FORMAT=NUMX12. AS capital_requirements, 
          /* rea_credit_risk */
            (t2.rea_credit_risk/t4.total_owner_count) FORMAT=NUMX12. AS rea_credit_risk, 
          /* allocated_capital */
            (t2.allocated_capital/t4.total_owner_count) FORMAT=NUMX12. AS allocated_capital
      FROM WORK.QUERY_FOR_CUSTOMER_0000 t1
           LEFT JOIN WORK.QUERY_FOR_DWI_CREDIT_CARD_BALANC t8 ON (t1.bank_id = t8.bank_id) AND (t1.ssn_id = t8.AH_SSN)
           LEFT JOIN WORK.QUERY_FOR_DWI_CUSTODY_0000 t9 ON (t1.bank_id = t9.bank_id) AND (t1.customer_id = 
          t9.customer_id)
           LEFT JOIN WORK.QUERY_FOR_DWI_ACCOUNT_ATTR_DAILY t4 ON (t1.bank_id = t4.bank_id) AND (t1.account_id = 
          t4.account_id)
           LEFT JOIN WORK.QUERY_FOR_DWI_ACCOUNT_BALANCE_AV t7 ON (t1.bank_id = t7.bank_id) AND (t1.account_id = 
          t7.account_id)
           LEFT JOIN WORK.QUERY_FOR_DWI_ACCOUNT_ALLOC_0000 t2 ON (t1.bank_id = t2.bank_id) AND (t1.account_id = 
          t2.credit_number);
QUIT;
/* --- End of code for "calc per account". --- */

/* --- Start of code for "calc per customer". --- */
%_eg_conditional_dropds(WORK.QUERY_FOR_CUSTOMER2_0000);

PROC SQL;
   CREATE TABLE WORK.QUERY_FOR_CUSTOMER2_0000 AS 
   SELECT DISTINCT t1.information_date, 
          t1.bank_id, 
          t1.customer_id, 
          t1.ssn_id, 
          t1.customer_type, 
          t1.name, 
          t1.result_office_id, 
          t1.advisor1_id, 
          /* SUM_of_deposit_balance */
            (sum(case when deposit_balance is not missing then deposit_balance else 0 end)) AS SUM_of_deposit_balance, 
          /* SUM_of_INL_MEAN */
            (SUM(t1.INL_MEAN)) FORMAT=NUMX12. AS SUM_of_INL_MEAN, 
          /* SUM_of_lending_balance */
            (sum(case when lending_balance is not missing then lending_balance else 0 end)) AS SUM_of_lending_balance, 
          /* SUM_of_UTL_MEAN */
            (SUM(t1.UTL_MEAN)) FORMAT=NUMX12. AS SUM_of_UTL_MEAN, 
          t1.UTL_CREDITCARD, 
          /* own_funds */
            (case when t1.own_funds is not missing then t1.own_funds else 0 end) AS own_funds, 
          /* FV_DISK */
            (case when t1.FV_DISK is not missing then t1.FV_DISK else 0 end) AS FV_DISK, 
          /* FV_KONS */
            (case when t1.FV_KONS is not missing then t1.FV_KONS else 0 end) AS FV_KONS, 
          /* FV_OVRIGT */
            (case when t1.FV_OVRIGT is not missing then t1.FV_OVRIGT else 0 end) AS FV_OVRIGT, 
          /* custody_market_value */
            (case when custody_market_value is not missing then custody_market_value else 0 end) AS custody_market_value, 
          t1.aum_sum, 
          /* SUM_of_capital_requirements */
            (SUM(t1.capital_requirements)) AS SUM_of_capital_requirements, 
          /* SUM_of_rea_credit_risk */
            (SUM(t1.rea_credit_risk)) AS SUM_of_rea_credit_risk, 
          /* SUM_of_allocated_capital */
            (SUM(t1.allocated_capital)) AS SUM_of_allocated_capital
      FROM WORK.QUERY_FOR_CUSTOMER2 t1
      GROUP BY t1.information_date,
               t1.bank_id,
               t1.customer_id;
QUIT;
/* --- End of code for "calc per customer". --- */

/* --- Start of code for "prepare customer table". --- */
%_eg_conditional_dropds(WORK.customer_balance_pre);

PROC SQL;
   CREATE TABLE WORK.customer_balance_pre(label="WORK.customer_balance") AS 
   SELECT t1.information_date, 
          t1.bank_id, 
          t1.customer_id, 
          t1.result_office_id, 
          t1.advisor1_id, 
          /* deposit_balance */
            (SUM(t1.SUM_of_deposit_balance)) AS deposit_balance, 
          /* lending_balance */
            (SUM(t1.SUM_of_lending_balance)) AS lending_balance, 
          /* custody_market_value */
            (SUM(t1.custody_market_value)) AS custody_market_value, 
          /* credit_card_lending_balance */
            (case when t1.UTL_CREDITCARD is not missing then t1.UTL_CREDITCARD else 0 end) AS 
            credit_card_lending_balance, 
          /* deposit_balance_avg_m */
            (case when t1.SUM_of_INL_MEAN is not missing then t1.SUM_of_INL_MEAN else 0 end) AS deposit_balance_avg_m, 
          /* lending_balance_avg_m */
            (case when t1.SUM_of_UTL_MEAN is not missing then t1.SUM_of_UTL_MEAN else 0 end) AS lending_balance_avg_m, 
          /* aab_own_funds_market_value */
            (SUM(t1.own_funds)) AS aab_own_funds_market_value, 
          /* custody_discretionary_mandate_mv */
            (SUM(t1.FV_DISK)) AS custody_discretionary_mandate_mv, 
          /* custody_consultative_mandate_mv */
            (SUM(t1.FV_KONS)) AS custody_consultative_mandate_mv, 
          /* custody_other_mandate_mv */
            (SUM(t1.FV_OVRIGT)) AS custody_other_mandate_mv, 
          t1.aum_sum AS aum_amt, 
          /* rea_amt */
            (t1.SUM_of_rea_credit_risk+t2.rea) AS rea_amt, 
          /* capital_requirement_amt */
            (t1.SUM_of_capital_requirements+t2.capital_requirements) AS capital_requirement_amt, 
          /* allocated_capital_amt */
            (t1.SUM_of_allocated_capital+t2.allocated_capital) AS allocated_capital_amt, 
          /* loaded_dt */
            (datetime()) FORMAT=datetime20. AS loaded_dt
      FROM WORK.QUERY_FOR_CUSTOMER2_0000 t1
           LEFT JOIN WORK.QUERY_FOR_DWI_CUST_ALLOC_CAP_TUR t2 ON (t1.bank_id = t2.bank_id) AND (t1.customer_id = 
          t2.customer_id)
      GROUP BY t1.information_date,
               t1.bank_id,
               t1.customer_id;
QUIT;
/* --- End of code for "prepare customer table". --- */

/* --- Start of code for "Query Builder". --- */
%_eg_conditional_dropds(WORK.customer_balance);


PROC SQL;
   CREATE TABLE WORK.customer_balance AS 
   SELECT DISTINCT t1.information_date, 
          t1.bank_id, 
          t1.customer_id, 
          t1.result_office_id, 
          t1.advisor1_id, 
          /* business_volume */
            (t1.deposit_balance+lending_balance+custody_market_value) AS business_volume, 
          /* business_volume_eur */
            (case when t1.bank_id='B' then (t1.deposit_balance+lending_balance+custody_market_value)*t2.mid_rate
            else (t1.deposit_balance+lending_balance+custody_market_value)
            end) AS business_volume_eur, 
          /* investable_finances_amt */
            (t1.deposit_balance+t1.custody_market_value) AS investable_finances_amt, 
          t1.deposit_balance, 
          t1.lending_balance, 
          t1.custody_market_value, 
          t1.credit_card_lending_balance, 
          t1.deposit_balance_avg_m, 
          t1.lending_balance_avg_m, 
          t1.aab_own_funds_market_value, 
          t1.custody_discretionary_mandate_mv, 
          t1.custody_consultative_mandate_mv, 
          t1.custody_other_mandate_mv, 
          /* aum_amt */
            (case when t1.aum_amt is not missing then t1.aum_amt else 0 end) AS aum_amt, 
          /* rea_amt */
            (case when t1.rea_amt is not missing then t1.rea_amt else 0 end) AS rea_amt, 
          /* capital_requirement_amt */
            (case when t1.capital_requirement_amt is not missing then t1.capital_requirement_amt else 0 end) AS 
            capital_requirement_amt, 
          /* allocated_capital_amt */
            (case when t1.allocated_capital_amt is not missing then t1.allocated_capital_amt else 0 end) AS 
            allocated_capital_amt, 
          t1.loaded_dt
      FROM WORK.CUSTOMER_BALANCE_PRE t1
           LEFT JOIN WORK.QUERY_FOR_EXCHANGE_RATES t2 ON (t1.information_date = t2.information_date);
QUIT;
