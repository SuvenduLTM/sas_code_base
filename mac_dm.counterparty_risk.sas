option DBIDIRECTEXEC;

proc datasets lib = work nolist nowarn memtype = (data view);
   delete W48364MB;
quit;

proc sql;
   create view work.W48364MB as
   select distinct
      basel_irb.information_date length = 4   
         format = FINDFDD10.
         informat = DDMMYY10.
         label = 'Information date of the record',
      basel_irb.bank_id length = 1   
         label = 'Bank ID code: A = ÅB Finland, B = ÅB Sweden',
      basel_irb.pd_class_pct length = 8   
         format = 10.7
         label = 'Probability default class percentage',
      cat(account.bank_id, account.owner_id) as counterparty_identifier length = 60   
         label = 'Counterparty identifier',
      counterparty_reference.name length = 150   
         label = 'Customer Name (all customers)'
   from
      work.basel_irb as basel_irb left join 
      work.account as account
         on
         (
            basel_irb.information_date = account.information_date
            and basel_irb.bank_id = account.bank_id
            and basel_irb.account_id = account.account_id
         ) left join 
      work.counterparty_reference as counterparty_reference
         on
         (
            account.information_date = counterparty_reference.information_date
            and account.bank_id = counterparty_reference.bank_id
            and account.owner_ssn_id = counterparty_reference.ssn_id
         )
   where
      basel_irb.pd_class_pct <> 0
      and counterparty_reference.counterparty_identifier NOT IS MISSING 
   ;
quit;

