data &_OUTPUT1 ;
  set &_INPUT1 ;
  length note_txt $40 ;
  if Exposure_after_exempt_n_crm < 0 then do;
    xmpts=sum(crm__financial_guarantees, _real_estate,_Funded_credit_prot_not_subst,_value_adjust_and_provis,0) ;
    if abs(crm__financial_guarantees) > 0 then do ;
      crm__financial_guarantees=round(crm__financial_guarantees-Exposure_after_exempt_n_crm*(crm__financial_guarantees/xmpts),0.01);
      note_txt='crm__financial_guarantees adjusted (maybe others)' ;
    end ;
    if abs(_real_estate) > 0 then do ;
      _real_estate=round(_real_estate-Exposure_after_exempt_n_crm*(_real_estate/xmpts),0.01);
      note_txt='_real_estate adjusted (maybe others)' ;
    end ;
    if abs(_funded_credit_prot_not_subst) > 0 then do ;
      _Funded_credit_prot_not_subst=round(_Funded_credit_prot_not_subst-Exposure_after_exempt_n_crm*(_Funded_credit_prot_not_subst/xmpts),0.01);
      note_txt='_funded_credit_prot_not_subst adjusted (maybe others)' ;
    end ;
    if abs(_value_adjust_and_provis) > 0 then do ;
      _value_adjust_and_provis=round(_value_adjust_and_provis-Exposure_after_exempt_n_crm*(_value_adjust_and_provis/xmpts),0.01);
      note_txt='_value_adjust_and_provis adjusted (maybe others)' ;
    end ;
    Exposure_after_exempt_n_crm=round(sum(debt_instruments, loan_commitments, financial_guarantees, other_commitments, _value_adjust_and_provis, 
      crm__financial_guarantees, _funded_credit_prot_not_subst, _real_estate, _amounts_exempted),0.01) ;
  end ;
  drop xmpts ;
run ;

